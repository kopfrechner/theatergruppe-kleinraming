---
import MemberCard from './MemberCard.astro';

interface Props {
  spieler: Array<{
    theatermenschen_id: {
      name: string;
      foto?: any;
    };
    rolle_name?: string;
    rolle_beschreibung?: string;
  }>;
}

const { spieler } = Astro.props;
---

<div class="cast-section">
  <h3>Besetzung</h3>
  <div class="cast-grid">
    {
      spieler.map((s) => (
        <MemberCard
          name={s.theatermenschen_id.name}
          role={s.rolle_name}
          roleDescription={s.rolle_beschreibung}
          image={s.theatermenschen_id.foto}
        />
      ))
    }
  </div>
</div>

<style>
  .cast-section {
    margin-top: 3rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 2rem;
  }

  .cast-section h3 {
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .cast-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
</style>
