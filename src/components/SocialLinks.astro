---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['social-links', className]}>
  <a
    href="https://www.facebook.com/Theatergruppe.Kleinraming/"
    target="_blank"
    rel="noopener noreferrer"
    class="social-icon facebook"
    aria-label="Facebook"
    data-umami-event="Facebook Klick"
  >
    <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor">
      <path
        d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
      ></path>
    </svg>
  </a>
  <a
    href="https://www.instagram.com/theatergruppe.kleinraming/"
    target="_blank"
    rel="noopener noreferrer"
    class="social-icon instagram"
    aria-label="Instagram"
    data-umami-event="Instagram Klick"
  >
    <svg
      viewBox="0 0 24 24"
      width="24"
      height="24"
      fill="none"
      stroke="url(#insta-grad-shared)"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
    </svg>
  </a>
</div>

<!-- Shared SVG Gradients -->
<svg width="0" height="0" style="position: absolute;" aria-hidden="true">
  <defs>
    <linearGradient id="insta-grad-shared" x1="100%" y1="100%" x2="0%" y2="0%">
      <stop stop-color="#f09433" offset="0%"></stop>
      <stop stop-color="#e6683c" offset="25%"></stop>
      <stop stop-color="#dc2743" offset="50%"></stop>
      <stop stop-color="#cc2366" offset="75%"></stop>
      <stop stop-color="#bc1888" offset="100%"></stop>
    </linearGradient>
  </defs>
</svg>

<style>
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Default icon size (used in footer) */
  .social-icon {
    width: 32px;
    height: 32px;
  }

  .social-icon.facebook {
    color: #1877f2 !important;
  }

  .social-icon:hover {
    transform: translateY(-2px);
    filter: brightness(1.2);
  }
</style>
