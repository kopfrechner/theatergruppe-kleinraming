---
// Logo.astro — Theater comedy/tragedy masks icon + wordmark
---

<div class="logo-wrapper">
  <div class="logo-text">
    <span class="logo-name">Theatergruppe <strong>Kleinraming</strong></span>
    <span class="logo-since">seit 1905</span>
  </div>
</div>

<style>
  .logo-wrapper {
    display: flex;
    align-items: center;
    min-height: 40px;
    min-width: 160px;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .logo-name {
    font-family: var(--font-heading, 'Outfit', sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-main, #f3f4f6);
    letter-spacing: 0.02em;
    min-width: 140px; /* Prevent shrinking before font loads */
  }

  @media (min-width: 380px) {
    .logo-name {
      white-space: nowrap;
    }
  }

  .logo-name strong {
    font-weight: 800;
    color: var(--accent-green, #8fc238);
  }

  .logo-since {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.55rem;
    color: var(--text-muted, #9ca3af);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-top: 0.1rem;
  }

  @media (min-width: 1024px) {
    .logo-icon {
      width: 4rem;
    }
    .logo-name {
      font-size: 1rem;
    }
    .logo-since {
      font-size: 0.6rem;
    }
  }
</style>
