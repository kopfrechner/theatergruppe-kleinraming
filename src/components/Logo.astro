---
// Logo.astro — Original logo image
---

<div class="logo-wrapper">
  <img src="/Logo_Original.png" alt="Theatergruppe Kleinraming Logo" class="header-logo" />
</div>

<style>
  .logo-wrapper {
    display: flex;
    align-items: center;
    padding: 0.25rem 0;
  }

  .header-logo {
    height: 40px;
    width: auto;
    display: block;
    object-fit: contain;
  }

  @media (min-width: 768px) {
    .header-logo {
      height: 54px;
    }
  }
</style>
