---
import GalleryImage from './GalleryImage.astro';
import 'photoswipe/style.css';

interface Props {
  images: Array<{
    src: string;
    width: number;
    height: number;
    thumbnail: string;
    id: string;
  }>;
  title: string;
}

const { images, title } = Astro.props;
---

<div class="gallery">
  <div class="grid-3 pswp-gallery" id="play-gallery">
    {
      images.map((img, index) => (
        <GalleryImage
          src={img.thumbnail}
          largeSrc={img.src}
          alt={`${title} - Galeriebild ${index + 1}`}
          width={400}
          origWidth={img.width}
          origHeight={img.height}
          lightbox={true}
        />
      ))
    }
  </div>
</div>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';

  let slideshowInterval: any;

  const lightbox = new PhotoSwipeLightbox({
    gallery: '#play-gallery',
    children: 'a',
    pswpModule: () => import('photoswipe'),
    showHideAnimationType: 'zoom',
    bgOpacity: 0.95,
  });

  lightbox.on('uiRegister', function () {
    const pswp = lightbox.pswp;
    if (!pswp || !pswp.ui) return;

    pswp.ui.registerElement({
      name: 'download-button',
      order: 10,
      isButton: true,
      tagName: 'a',
      html: {
        isCustomSVG: true,
        inner:
          '<path d="M20.5 14.3 17.1 18V10h-2.2v7.9l-3.4-3.6L10 15.8l5 5.2 5-5.2ZM10 13.3a2 2 0 0 1-2-2V4.7c0-1.1.9-2 2-2h12a2 2 0 0 1 2 2v6.6a2 2 0 0 1-2 2H10Z" fill="currentColor"/>',
        outlineID: 'pswp__icn-download',
      },
      onInit: (el: any, pswp: any) => {
        el.setAttribute('download', '');
        el.setAttribute('target', '_blank');
        el.setAttribute('rel', 'noopener');
        el.setAttribute('title', 'Bild herunterladen');
        pswp.on('change', () => {
          el.href = pswp.currSlide.data.src;
        });
      },
    });

    pswp.ui.registerElement({
      name: 'play-pause-button',
      order: 9,
      isButton: true,
      html: '<svg aria-hidden="true" class="pswp__icn pswp__icn-play" viewBox="0 0 32 32" width="32" height="32"><path d="M10 6l16 10-16 10z" fill="currentColor"/></svg><svg aria-hidden="true" class="pswp__icn pswp__icn-pause" viewBox="0 0 32 32" width="32" height="32" style="display:none"><path d="M8 6h6v20H8zM18 6h6v20h-6z" fill="currentColor"/></svg>',
      onClick: (_event: any, el: any, pswpInstance: any) => {
        if (slideshowInterval) {
          clearInterval(slideshowInterval);
          slideshowInterval = null;
          el.querySelector('.pswp__icn-play').style.display = 'block';
          el.querySelector('.pswp__icn-pause').style.display = 'none';
        } else {
          slideshowInterval = setInterval(() => {
            pswpInstance.next();
          }, 3000);
          el.querySelector('.pswp__icn-play').style.display = 'none';
          el.querySelector('.pswp__icn-pause').style.display = 'block';
        }
      },
    });
  });

  lightbox.on('close', () => {
    if (slideshowInterval) {
      clearInterval(slideshowInterval);
      slideshowInterval = null;
    }
  });

  lightbox.init();
</script>

<style>
  .gallery {
    margin-top: 3rem;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: 1fr; /* 1 col on mobile */
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 640px) {
    .grid-3 {
      grid-template-columns: repeat(2, 1fr); /* 2 col on tablet */
    }
  }

  @media (min-width: 992px) {
    .grid-3 {
      grid-template-columns: repeat(3, 1fr); /* 3 col on desktop */
    }
  }

  :global(.pswp) {
    --pswp-bg: rgba(10, 10, 10, 0.98);
    --pswp-placeholder-bg: #1a1a1a;
  }

  :global(.pswp__button--download-button),
  :global(.pswp__button--play-pause-button) {
    opacity: 0.75;
  }

  :global(.pswp__button--download-button:hover),
  :global(.pswp__button--play-pause-button:hover) {
    opacity: 1;
    color: var(--accent-green);
  }
</style>
