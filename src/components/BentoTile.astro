---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={['glass-panel bento-tile', className]}>
  <slot />
</div>

<style>
  .bento-tile {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease,
      box-shadow 0.3s ease;
    min-height: 250px;
  }

  .bento-tile:hover {
    transform: translateY(-5px);
    border-color: var(--accent-green);
  }

  @media (min-width: 768px) {
    .bento-tile {
      padding: 2.5rem;
      min-height: 200px; /* Instead of 0 to maintain grid stability */
    }
  }
</style>
