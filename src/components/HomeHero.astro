---
import heroBg from '../assets/Gemini_Generated_Image_nn40dqnn40dqnn40.png';

interface Props {
  isTicketsActive: boolean;
  lastPlay?: {
    id: string | number;
    slug?: string;
  } | null;
}

const { isTicketsActive, lastPlay } = Astro.props;
---

<section class="hero" style={`background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url(${heroBg.src});`}>
  <div class="container hero-content">
    <h1>
      Willkommen bei der<br /><span class="text-green"
        >Theatergruppe Kleinraming</span
      >
    </h1>
    <p class="hero-subtitle">
      Leidenschaft für die Bühne, Begeisterung für das Publikum.
    </p>
    <div class="hero-actions">
      {
        isTicketsActive ? (
          <>
            <a href="/tickets" class="btn">
              Tickets reservieren
            </a>
            <a href="/stuecke" class="btn btn-outline">
              Alle Stücke ansehen
            </a>
          </>
        ) : (
          <>
            {lastPlay && (
              <a href={`/stuecke/${lastPlay.slug || lastPlay.id}`} class="btn">
                Zum letzten Stück
              </a>
            )}
            <a href="/stuecke" class="btn btn-outline">
              Alle Stücke ansehen
            </a>
          </>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 80vh;
    width: 100%;
    margin-top: -80px; /* Pull under the sticky header */
    padding-top: 80px; /* Offset content so it stays centered in viewport */
    display: flex;
    align-items: center;
    background-size: cover;
    background-position: center 42%;
    background-repeat: no-repeat;
    border-bottom: 1px solid rgba(255, 230, 200, 0.05);
    margin-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 40%;
    background: linear-gradient(to top, var(--bg-color), transparent);
    pointer-events: none;
  }

  .hero-content {
    text-align: center;
    transform: translateY(2rem); /* Fine-tune vertical position to center in stage opening */
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: 3.5rem;
    }
  }

  .text-green {
    color: var(--accent-green);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-actions {
      flex-direction: row;
    }
  }
</style>
