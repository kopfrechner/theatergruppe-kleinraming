---
import { getImage } from 'astro:assets';
import heroBgSrc from '../assets/hero-stage.webp';

interface Props {
  isTicketsActive: boolean;
  lastPlay?: {
    id: string | number;
    slug?: string;
  } | null;
}

const { isTicketsActive, lastPlay } = Astro.props;

const optimizedBg = await getImage({
  src: heroBgSrc,
  width: 1920,
  format: 'webp',
  quality: 80,
});
---

<section class="hero">
  <div
    class="hero-bg"
    style={`background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url(${optimizedBg.src});`}
  >
  </div>
  <div class="container hero-content">
    <h1>
      Willkommen bei der<br /><span class="text-green"
        >Theatergruppe Kleinraming</span
      >
    </h1>
    <p class="hero-subtitle">
      Leidenschaft für die Bühne, Begeisterung für das Publikum.
    </p>
    <div class="hero-actions">
      {
        isTicketsActive ? (
          <>
            <a
              href="/tickets"
              class="btn"
              data-umami-event="Tickets Reservieren Klick"
              data-umami-event-source="Startseite Hero"
            >
              Tickets reservieren
            </a>
            <a
              href="/stuecke"
              class="btn btn-outline"
              data-umami-event="Stuecke Archiv Klick"
              data-umami-event-source="Startseite Hero"
            >
              Alle Stücke ansehen
            </a>
          </>
        ) : (
          <>
            {lastPlay && (
              <a
                href={`/stuecke/${lastPlay.slug || lastPlay.id}`}
                class="btn"
                data-umami-event="Rückblick Klick"
                data-umami-event-source="Startseite Hero"
              >
                Zum letzten Stück
              </a>
            )}
            <a
              href="/stuecke"
              class="btn btn-outline"
              data-umami-event="Stuecke Archiv Klick"
              data-umami-event-source="Startseite Hero"
            >
              Alle Stücke ansehen
            </a>
          </>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 82vh; /* More stable than svh during load */
    width: 100%;
    display: flex;
    align-items: center;
    margin-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero {
      min-height: 600px; /* Fixed fallback for desktop stability */
    }
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center 42%;
    background-repeat: no-repeat;
    z-index: 0;
  }

  .hero-content {
    text-align: center;
    z-index: 1;
  }

  @media (max-height: 600px) {
    .hero {
      min-height: 450px; /* Ensure enough height for content even on very short screens */
    }
    .hero-content {
      transform: translateY(1rem);
    }
    .hero h1 {
      font-size: 1.8rem;
    }
    .hero-subtitle {
      margin-bottom: 1.25rem;
      font-size: 1.1rem;
    }
    .hero-actions {
      flex-direction: row;
    }
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    line-height: 1.1;
    color: #faf7f2; /* Always light on dark stage image */
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: 3.5rem;
    }
  }

  .text-green {
    color: var(--accent-green);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: #b5ada3; /* Forced muted light color */
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-actions {
      flex-direction: row;
    }
  }
</style>
