---
import { getImage } from "astro:assets";
import heroBgSrc from "../assets/hero-stage.webp";

interface Props {
  isTicketsActive: boolean;
  lastPlay?: {
    id: string | number;
    slug?: string;
  } | null;
}

const { isTicketsActive, lastPlay } = Astro.props;

const optimizedBg = await getImage({
  src: heroBgSrc,
  width: 1920,
  format: "webp",
  quality: 80,
});
---

<section
  class="hero"
  style={`background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url(${optimizedBg.src});`}
>
  <div class="container hero-content">
    <h1>
      Willkommen bei der<br /><span class="text-green"
        >Theatergruppe Kleinraming</span
      >
    </h1>
    <p class="hero-subtitle">
      Leidenschaft für die Bühne, Begeisterung für das Publikum.
    </p>
    <div class="hero-actions">
      {
        isTicketsActive ? (
          <>
            <a href="/tickets" class="btn">
              Tickets reservieren
            </a>
            <a href="/stuecke" class="btn btn-outline">
              Alle Stücke ansehen
            </a>
          </>
        ) : (
          <>
            {lastPlay && (
              <a href={`/stuecke/${lastPlay.slug || lastPlay.id}`} class="btn">
                Zum letzten Stück
              </a>
            )}
            <a href="/stuecke" class="btn btn-outline">
              Alle Stücke ansehen
            </a>
          </>
        )
      }
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 82vh;
    width: 100%;
    margin-top: -80px; /* Pull under the sticky header */
    padding-top: 80px; /* Offset content so it stays centered in viewport */
    display: flex;
    align-items: center;
    background-size: cover;
    background-position: center 42%;
    background-repeat: no-repeat;
    margin-bottom: 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 200px;
    background: linear-gradient(
      to bottom,
      var(--bg-color) 0%,
      rgba(17, 16, 15, 0.8) 40%,
      transparent 100%
    );
    pointer-events: none;
    z-index: 0;
  }

  .hero::after {
    content: "";
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 50%;
    background: linear-gradient(
      to top,
      var(--bg-color) 5%,
      rgba(17, 16, 15, 0.8) 20%,
      transparent 100%
    );
    pointer-events: none;
  }

  .hero-content {
    text-align: center;
    transform: translateY(
      2.5rem
    ); /* Fine-tune vertical position to center in stage opening */
    z-index: 1;
  }

  @media (max-height: 600px) {
    .hero {
      min-height: 450px; /* Ensure enough height for content even on very short screens */
    }
    .hero-content {
      transform: translateY(1rem);
    }
    .hero h1 {
      font-size: 1.8rem;
    }
    .hero-subtitle {
      margin-bottom: 1.25rem;
      font-size: 1.1rem;
    }
    .hero-actions {
      flex-direction: row;
    }
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: 3.5rem;
    }
  }

  .text-green {
    color: var(--accent-green);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-actions {
      flex-direction: row;
    }
  }
</style>
