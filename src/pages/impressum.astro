---
import Layout from '../layouts/Layout.astro';
import client, { readSingleton } from '../lib/directus';

const impressum = await client.request(readSingleton('impressum'));
---

<Layout title="Impressum">
  <div class="container page-header">
    <h1>Impressum</h1>
  </div>

  <section class="container legal-section">
    <div class="glass-panel content-box">
      <div set:html={impressum.content} />
    </div>
  </section>
</Layout>

<style>
  .legal-section {
    max-width: 800px;
    margin-bottom: 5rem;
  }
  .content-box {
    padding: 3rem;
  }
</style>
