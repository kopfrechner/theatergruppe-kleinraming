---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Startseite">
  <section class="hero">
    <div class="container hero-content">
      <h1>Willkommen bei der<br/><span class="text-green">Theatergruppe Kleinraming</span></h1>
      <p class="hero-subtitle">Leidenschaft für die Bühne, Begeisterung für das Publikum.</p>
      <div class="hero-actions">
        <a href="/tickets" class="btn">Tickets kaufen</a>
        <a href="/stuecke" class="btn btn-outline">Letzte Stücke ansehen</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, transparent 0%, var(--bg-color) 100%);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-content {
    text-align: center;
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: 3.5rem;
    }
  }

  .text-green {
    color: var(--accent-green);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-actions {
      flex-direction: row;
    }
  }
</style>
