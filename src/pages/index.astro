---
import Layout from '../layouts/Layout.astro';
import directus, { DIRECTUS_URL } from '../lib/directus';
import { readItems, readSingleton } from '@directus/sdk';
import { Image } from 'astro:assets';

// 1. Fetch Startseite Config
const startseite = await directus.request(
  readSingleton('startseite', {
    fields: ['emotionen_titel', 'emotionen_bild', 'impressionen_gallerie.*']
  })
).catch(() => null);

// 2. Fetch Ticket Promotion
const ticketPromo = await directus.request(
  readSingleton('ticket_promotion', {
    fields: ['aktiv', 'titel', 'kurzbeschreibung', 'termine', 'ticketlotse_link']
  })
).catch(() => ({ aktiv: false }));

// 3. Fallback logic if not active
let highlightPlay: any = null;
if (!ticketPromo?.aktiv) {
  const latestPlays = await directus.request(
    readItems('stuecke', {
      filter: { status: { _eq: 'published' } },
      sort: ['-auffuehrung_im_jahr'],
      limit: 1
    })
  );
  if (latestPlays.length > 0) {
    const play = latestPlays[0];
    const cleanSynopsis = (play.synopsis || '').replace(/<[^>]*>?/gm, '');
    highlightPlay = {
      isHistorical: true,
      titel: play.titel,
      text: cleanSynopsis.length > 180 ? cleanSynopsis.substring(0, 180).trim() + '...' : cleanSynopsis,
      link: `/stuecke/${play.id}`,
      buttonText: 'Details ansehen',
      status: 'Rückblick',
      termine: []
    };
  }
} else {
  // Parse multiline text into array, ignore empty lines
  const termineArray = ticketPromo.termine 
    ? ticketPromo.termine.split('\n').map(t => t.trim()).filter(t => t.length > 0) 
    : [];

  highlightPlay = {
    isHistorical: false,
    titel: ticketPromo.titel,
    text: ticketPromo.kurzbeschreibung,
    link: ticketPromo.ticketlotse_link || '/tickets',
    buttonText: 'Tickets sichern',
    status: 'Nächste Premiere',
    termine: termineArray
  };
}

// Prepare impression images from CMS
const impressionImages = startseite?.impressionen_gallerie 
  ? startseite.impressionen_gallerie.map((img: any) => `${DIRECTUS_URL}/assets/${img.directus_files_id || img}`)
  : [];

const emotionImage = startseite?.emotionen_bild 
  ? `${DIRECTUS_URL}/assets/${startseite.emotionen_bild}`
  : null;

const emotionTitel = startseite?.emotionen_titel || '';
---

<Layout title="Startseite">
  <section class="hero">
    <div class="container hero-content">
      <h1>Willkommen bei der<br/><span class="text-green">Theatergruppe Kleinraming</span></h1>
      <p class="hero-subtitle">Leidenschaft für die Bühne, Begeisterung für das Publikum.</p>
      <div class="hero-actions">
        {ticketPromo?.aktiv && <a href="/tickets" class="btn">Tickets reservieren</a>}
        <a href="/stuecke" class="btn btn-outline">Alle Stücke ansehen</a>
      </div>
    </div>
  </section>

  <section class="container bento-section">
    <div class="bento-grid">
      <!-- Tile A: Highlight Play (Dynamic) -->
      {highlightPlay && (
        <div class="glass-panel bento-tile tile-next-play">
          <span class="play-status">{highlightPlay.status}</span>
          <h2>{highlightPlay.titel}</h2>
          <p>{highlightPlay.text}</p>
          
          {highlightPlay.termine && highlightPlay.termine.length > 0 && (
            <div class="play-dates">
              <strong>Termine:</strong>
              <ul>
                {highlightPlay.termine.map((date: string) => <li>{date}</li>)}
              </ul>
            </div>
          )}

          <a href={highlightPlay.link} class="btn">{highlightPlay.buttonText}</a>
        </div>
      )}

      <!-- Tile B: Backstage Impression -->
      <div class="glass-panel bento-tile tile-image">
        {emotionImage ? (
          <Image 
            src={emotionImage} 
            alt={emotionTitel}
            width={800}
            height={600}
            format="webp"
            class="tile-bg-image"
          />
        ) : (
          <div class="tile-bg-image" style="background: rgba(255,255,255,0.02);"></div>
        )}
        <div class="tile-overlay">
          {emotionTitel && <h3>{emotionTitel}</h3>}
        </div>
      </div>

      <!-- Tile C: Tradition -->
      <div class="glass-panel bento-tile tile-stat">
        <span class="stat-number">1906</span>
        <span class="stat-label">Gründungsjahr</span>
        <p style="margin-top: 1rem; color: var(--text-muted); font-size: 0.9rem;">Über 100 Jahre Tradition in Kleinraming.</p>
      </div>

      <!-- Tile D: Actors Link -->
      <div class="glass-panel bento-tile tile-actors">
        <h3>Unsere Theatermenschen</h3>
        <p style="color: var(--text-muted); font-size: 0.9rem;">Das Herzstück unseres Vereins – vor und hinter der Bühne.</p>
        <a href="/theatermenschen" class="btn btn-outline">Zum Ensemble</a>
      </div>
    </div>
  </section>

  <section class="container filmstrip-section">
    <div class="filmstrip-header">
      <h2>Impressionen</h2>
    </div>
    <div class="filmstrip-grid">
      {impressionImages.map((imgUrl: string) => (
        <div class="filmstrip-item">
          <Image 
            src={imgUrl} 
            alt="Impression" 
            width={600} 
            height={450} 
            format="webp"
          />
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, transparent 0%, var(--bg-color) 100%);
    border-bottom: 1px solid rgba(255, 230, 200, 0.05);
    margin-bottom: 4rem;
  }

  /* Bento Grid */
  .bento-section {
    margin-bottom: 6rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .bento-tile {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
    transition: var(--transition);
    min-height: 250px; /* Default height for mobile */
  }

  .tile-image {
    min-height: 300px; /* Larger height for image on mobile */
    padding: 0;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: 1.5fr 1fr;
      grid-template-rows: repeat(3, 200px);
    }

    .tile-next-play {
      grid-column: 1;
      grid-row: span 3;
    }

    .bento-tile {
      padding: 2.5rem;
      min-height: 0;
    }

    .tile-image {
      min-height: 0;
    }
  }

  .bento-tile:hover {
    transform: translateY(-5px);
    border-color: var(--accent-green);
  }

  .bento-tile .btn {
    width: 100%;
    text-align: center;
    margin-top: 1.5rem;
  }

  .tile-next-play h2 {
    color: var(--accent-gold);
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .tile-next-play p {
    color: var(--text-muted);
    margin-bottom: 2rem;
    max-width: 500px;
  }

  .play-status {
    display: inline-block;
    background: rgba(143, 194, 56, 0.15);
    color: var(--accent-green);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .play-dates {
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .play-dates ul {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .play-dates li {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    color: var(--text-main);
  }

  .tile-bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.5s ease;
  }

  .bento-tile:hover .tile-bg-image {
    transform: scale(1.05);
  }

  .tile-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    z-index: 1;
  }

  .tile-overlay h3 {
    margin: 0;
    font-size: 1.5rem;
    color: #fff;
  }

  .tile-stat {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    color: var(--accent-gold);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
  }

  .tile-actors h3 {
    color: var(--accent-green);
  }

  /* Filmstrip */
  .filmstrip-section {
    margin-bottom: 8rem;
  }

  .filmstrip-header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .filmstrip-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 992px) {
    .filmstrip-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .filmstrip-item {
    aspect-ratio: 4 / 3;
    background-color: var(--bg-color-light);
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .filmstrip-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .filmstrip-item:hover img {
    transform: scale(1.05);
  }

  .hero-content {
    text-align: center;
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: 3.5rem;
    }
  }

  .text-green {
    color: var(--accent-green);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-actions {
      flex-direction: row;
    }
  }
</style>
