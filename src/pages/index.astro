---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Startseite">
  <section class="hero">
    <div class="container hero-content">
      <h1>Willkommen bei der<br/><span class="text-green">Theatergruppe Kleinraming</span></h1>
      <p class="hero-subtitle">Leidenschaft für die Bühne, Begeisterung für das Publikum.</p>
      <div class="hero-actions">
        <a href="/tickets" class="btn">Tickets kaufen</a>
        <a href="/stuecke" class="btn btn-outline">Letzte Stücke ansehen</a>
      </div>
    </div>
  </section>

  <section class="container recent-plays">
    <h2 class="section-title">Unsere letzten Stücke</h2>
    <div class="grid grid-3">
      <!-- Dummy Cards -> Später dynamisch aus Content Collections gepullt -->
      <article class="glass-panel play-card">
        <div class="play-image-placeholder"></div>
        <div class="play-content">
          <h3>MS Rosta - Kreuzfahrt kuriosa!</h3>
          <p class="play-date">Saison 2026</p>
          <a href="/stuecke/ms-rosta" class="read-more">Mehr erfahren &rarr;</a>
        </div>
      </article>

      <article class="glass-panel play-card">
        <div class="play-image-placeholder"></div>
        <div class="play-content">
          <h3>Eine Sprachbox namens Alessa!</h3>
          <p class="play-date">Saison 2025</p>
          <a href="/stuecke/eine-sprachbox-namens-alessa" class="read-more">Mehr erfahren &rarr;</a>
        </div>
      </article>

      <article class="glass-panel play-card">
        <div class="play-image-placeholder"></div>
        <div class="play-content">
          <h3>Die Lügenglocke</h3>
          <p class="play-date">Saison 2024</p>
          <a href="/stuecke/die-luegenglocke" class="read-more">Mehr erfahren &rarr;</a>
        </div>
      </article>
    </div>
  </section>
</Layout>

<style>
  .hero {
    min-height: 70vh;
    display: flex;
    align-items: center;
    background: linear-gradient(180deg, rgba(10,10,10,0) 0%, var(--bg-color) 100%);
    background-color: #1a1a1a;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .hero-content {
    text-align: center;
  }

  .hero h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  @media (min-width: 768px) {
    .hero h1 {
      font-size: 3.5rem;
    }
  }

  .text-green {
    color: var(--accent-green);
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
    max-width: 600px;
    margin-inline: auto;
  }

  .hero-actions {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero-actions {
      flex-direction: row;
    }
  }

  .recent-plays {
    margin-top: 5rem;
    margin-bottom: 5rem;
  }

  .section-title {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 3rem;
  }

  .grid-3 {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .play-card {
    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .play-card:hover {
    transform: translateY(-5px);
  }

  .play-image-placeholder {
    height: 200px;
    background-color: var(--bg-color-light);
  }

  .play-content {
    padding: 1.5rem;
  }

  .play-date {
    color: var(--accent-green);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .read-more {
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
