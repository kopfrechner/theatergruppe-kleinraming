---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/HomeHero.astro';
import HighlightPlayTile from '../components/HighlightPlayTile.astro';
import ImageGallery from '../components/ImageGallery.astro';
import BentoTile from '../components/BentoTile.astro';
import directus, { DIRECTUS_URL, type Stueck } from '../lib/directus';
import { readItems, readSingleton } from '@directus/sdk';
import { Image, inferRemoteSize } from 'astro:assets';
import { mapHighlightPlay } from '../lib/mappers';

// 1. Fetch Data
const [startseite, ticketPromo, latestPlays] = (await Promise.all([
  directus
    .request(
      readSingleton('startseite', {
        fields: [
          'emotionen_titel',
          'emotionen_bild',
          'impressionen_gallerie.directus_files_id.*',
        ],
      } as any),
    )
    .catch(() => null),
  directus
    .request(
      readSingleton('ticket_promotion', {
        fields: [
          'anzeige_modus',
          'titel',
          'vorab_titel',
          'kurzbeschreibung',
          'vorab_text',
          'vorab_bild',
          'termin_1',
          'termin_2',
          'termin_3',
          'termin_4',
          'termin_5',
          'termin_6',
          'ticketlotse_link',
          'hauptfoto',
        ],
      } as any),
    )
    .catch(() => ({ anzeige_modus: 'inaktiv' }) as any),
  directus
    .request(
      readItems('stuecke', {
        fields: [
          'id',
          'titel',
          'synopsis',
          'auffuehrung_im_jahr',
          'titelfoto',
          'slug',
        ],
        sort: ['-auffuehrung_im_jahr'] as any,
        filter: { veroffentlicht: { _eq: true } } as any,
        limit: 1,
      }),
    )
    .catch(() => []),
])) as [any, any, Stueck[]];

const lastPlay = latestPlays.length > 0 ? latestPlays[0] : null;

// 2. Map Data
const highlightPlay = mapHighlightPlay(ticketPromo, lastPlay, DIRECTUS_URL);

const impressionImages =
  startseite?.impressionen_gallerie &&
  Array.isArray(startseite.impressionen_gallerie)
    ? startseite.impressionen_gallerie.map((img: any) => ({
        src: `${DIRECTUS_URL}/assets/${img.directus_files_id?.id || img.directus_files_id || img}`,
        width: img.directus_files_id?.width || 1600,
        height: img.directus_files_id?.height || 1200,
        thumbnail: `${DIRECTUS_URL}/assets/${img.directus_files_id?.id || img.directus_files_id || img}`,
        id: img.directus_files_id?.id || img.directus_files_id || img,
      }))
    : [];

const emotionImage = startseite?.emotionen_bild
  ? `${DIRECTUS_URL}/assets/${startseite.emotionen_bild}`
  : null;

const emotionTitel = startseite?.emotionen_titel || '';

// Infer dimensions for the emotion image to prevent cropping
let emotionWidth = 800;
let emotionHeight = 600;

if (emotionImage) {
  try {
    const dims = await inferRemoteSize(emotionImage);
    emotionWidth = dims.width;
    emotionHeight = dims.height;
  } catch (e) {
    console.warn('Could not infer remote size for emotion image', e);
  }
}
---

<Layout title="Startseite">
  <HomeHero
    isTicketsActive={ticketPromo?.anzeige_modus !== 'inaktiv'}
    lastPlay={lastPlay}
  />

  <section class="container bento-section">
    <div class="bento-grid">
      <!-- Tile A: Highlight Play (Dynamic) -->
      {highlightPlay && <HighlightPlayTile play={highlightPlay} />}

      <!-- Tile B: Backstage Impression -->
      <BentoTile class="tile-image">
        {
          emotionImage ? (
            <Image
              src={emotionImage}
              alt={emotionTitel}
              width={emotionWidth}
              height={emotionHeight}
              format="webp"
              class="tile-bg-image"
            />
          ) : (
            <div
              class="tile-bg-image"
              style="background: rgba(255,255,255,0.02);"
            />
          )
        }
        <div class="tile-overlay">
          {emotionTitel && <h3>{emotionTitel}</h3>}
        </div>
      </BentoTile>

      <!-- Tile C: Tradition -->
      <BentoTile class="tile-stat">
        <span class="stat-number">1906</span>
        <span class="stat-label">Gründungsjahr</span>
        <p
          style="margin-top: 1rem; color: var(--text-muted); font-size: 0.9rem;"
        >
          Über 100 Jahre Tradition in Kleinraming.
        </p>
      </BentoTile>

      <!-- Tile D: Actors Link -->
      <BentoTile class="tile-actors">
        <h3>Unsere Theatermenschen</h3>
        <p style="color: var(--text-muted); font-size: 0.9rem;">
          Das Herzstück unseres Vereins – vor und hinter der Bühne.
        </p>
        <a href="/theatermenschen" class="btn btn-outline">Zum Ensemble</a>
      </BentoTile>
    </div>
  </section>

  <section class="container impression-section">
    <h2>Impressionen</h2>
    <ImageGallery images={impressionImages} title="Impressionen" />
  </section>
</Layout>

<style>
  /* Bento Grid Layout */
  .bento-section {
    margin-bottom: 6rem;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  :global(.tile-image) {
    padding: 0 !important;
    min-height: 0 !important;
  }

  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: 1.5fr 1fr;
      grid-template-rows: auto 1fr 1fr;
    }

    :global(.tile-next-play) {
      grid-column: 1;
      grid-row: span 3;
    }
  }

  .tile-bg-image {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    z-index: 0;
    transition: transform 0.5s ease;
  }

  :global(.tile-image:hover) .tile-bg-image {
    transform: scale(1.05);
  }

  .tile-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.8) 0%, transparent 60%);
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    z-index: 1;
  }

  .tile-overlay h3 {
    margin: 0;
    font-size: 1.5rem;
    color: #fff;
  }

  :global(.tile-stat) {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .stat-number {
    font-family: var(--font-heading);
    font-size: 4rem;
    font-weight: 800;
    color: var(--accent-gold);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.9rem;
  }

  :global(.tile-actors) h3 {
    color: var(--accent-green);
  }

  .impression-section {
    margin-bottom: 8rem;
    text-align: center;
  }

  .impression-section h2 {
    margin-bottom: 3rem;
    font-size: 2.5rem;
  }
</style>
