---
import Layout from '../layouts/Layout.astro';
import directus from '../lib/directus';
import { readItems } from '@directus/sdk';

const members = await directus.request(
  readItems('theatermenschen', {
    filter: {
      status: { _eq: 'published' },
      aktiver_theatermensch: { _eq: true }
    },
    sort: ['name']
  })
);

const boardMembers = members.filter(m => m.vorstandsmitglied);
const activeMembers = members.filter(m => !m.vorstandsmitglied);
const DIRECTUS_URL = 'https://cms.kopfarbeit.dev';
---

<Layout title="Mitglieder">
  <div class="container page-header">
    <h1>Unsere Mitglieder</h1>
    <p class="subtitle">Das Team vor und hinter den Kulissen.</p>
  </div>

  <section class="container members-section">
    <h2 class="category-title">Unser Vorstand</h2>
    <div class="grid board-grid">
      {boardMembers.map(member => (
        <article class="glass-panel member-card board-card">
          <div class="member-photo-placeholder">
            {member.foto ? (
              <img 
                src={`${DIRECTUS_URL}/assets/${member.foto}?width=300&height=400&fit=cover`} 
                alt={member.name}
              />
            ) : (
              <div class="no-photo">Kein Foto verfügbar</div>
            )}
          </div>
          <div class="member-info">
            <h3>{member.name}</h3>
            <p class="member-role" style="white-space: pre-line;">{member.funktionen}</p>
            {member.steckbrief && <p class="member-profile">{member.steckbrief}</p>}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container members-section">
    <h2 class="category-title">Weitere aktive Theatermenschen</h2>
    <div class="grid members-grid">
      {activeMembers.map(member => (
        <article class="glass-panel member-card">
          <div class="member-photo-placeholder">
            {member.foto ? (
              <img 
                src={`${DIRECTUS_URL}/assets/${member.foto}?width=300&height=400&fit=cover`} 
                alt={member.name}
              />
            ) : (
              <div class="no-photo">Kein Foto verfügbar</div>
            )}
          </div>
          <div class="member-info">
            <h3>{member.name}</h3>
            <p class="member-role" style="white-space: pre-line;">{member.funktionen}</p>
            {member.steckbrief && <p class="member-profile">{member.steckbrief}</p>}
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 3rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 1rem auto;
  }

  .members-section {
    margin-bottom: 5rem;
  }

  .category-title {
    color: var(--accent-green);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
    margin-bottom: 3rem;
    text-align: center;
    font-size: 2rem;
  }

  .board-grid {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    justify-content: center;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .members-grid {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 2rem;
  }

  .member-card {
    text-align: center;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .board-card {
    border: 1px solid rgba(143, 194, 56, 0.3);
  }

  .member-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
  }

  .member-photo-placeholder {
    height: 320px;
    background-color: var(--bg-color-light);
    border-bottom: 2px solid var(--accent-green);
  }

  .member-photo-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .no-photo {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .member-info {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .member-role {
    color: var(--accent-green);
    font-weight: 600;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .member-profile {
    font-size: 0.85rem;
    margin-top: 1rem;
    color: #ccc;
    font-style: italic;
  }
</style>
