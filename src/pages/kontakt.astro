---
import Layout from '../layouts/Layout.astro';
import MemberCard from '../components/MemberCard.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { Mail, Phone } from '@lucide/astro';
import directus from '../lib/directus';
import { readItems, readSingleton } from '@directus/sdk';

// Fetch contact page configuration
const config = await directus
  .request(
    readSingleton('kontakt_seite', {
      fields: ['email', 'telefon', 'faq', 'location_name', 'map_embed'],
    }),
  )
  .catch(() => ({
    email: 'info@theatergruppe-kleinraming.at',
    telefon: '0680 / 3110037',
    faq: [],
    location_name: 'Gasthof Froschauer',
    map_embed: '',
  }));

// Fetch board members
const vorstand = await directus
  .request(
    readItems('theatermenschen', {
      filter: {
        vorstandsmitglied: { _eq: true },
      },
      fields: ['name', 'funktionen', 'foto'],
      sort: ['sort', 'name'],
    }),
  )
  .catch(() => []);

const contactEmail = config.email || 'info@theatergruppe-kleinraming.at';
const contactPhone = config.telefon || '0680 / 3110037';
const faqs = config.faq || [];
const locationName = config.location_name || 'Gasthof Froschauer';
const mapEmbed = config.map_embed || '';
---

<Layout
  title="Kontakt & FAQ"
  description="Haben Sie Fragen? Hier finden Sie Kontaktmöglichkeiten zur Theatergruppe Kleinraming sowie Antworten auf häufig gestellte Fragen."
>
  <div class="container page-header">
    <h1>Kontakt</h1>
    <p class="subtitle">
      Du hast Fragen, Wünsche oder Anregungen? Wir freuen uns auf deine
      Nachricht!
    </p>
  </div>

  <section class="container contact-section">
    <div class="grid grid-2">
      <div class="glass-panel contact-card">
        <h2>Allgemeine Anfragen</h2>
        <div class="contact-methods">
          <div class="method">
            <span class="icon"><Mail size={20} /></span>
            <div>
              <strong>E-Mail</strong>
              <p><a href={`mailto:${contactEmail}`}>{contactEmail}</a></p>
            </div>
          </div>
          <div class="method">
            <span class="icon"><Phone size={20} /></span>
            <div>
              <strong>Telefon</strong>
              <p>
                <a href={`tel:${contactPhone.replace(/\s/g, '')}`}
                  >{contactPhone}</a
                >
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="glass-panel contact-card">
        <h2>Social Media</h2>
        <p>Folge uns für aktuelle Infos und Einblicke hinter die Kulissen</p>
        <SocialLinks class="contact-socials" umamiSource="kontakte" />
      </div>
    </div>

    {
      faqs.length > 0 && (
        <div class="glass-panel faq-section">
          <h2>Häufig gestellte Fragen (FAQ)</h2>
          <div class="faq-list">
            {faqs.map((item) => (
              <div class="faq-item">
                <h3>{item.frage}</h3>
                <p>{item.antwort}</p>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <div class="glass-panel board-section">
      <h2>Unser Vorstand</h2>
      <p class="section-intro">
        Für spezifische Anliegen kannst du dich auch direkt an unsere
        Vorstandsmitglieder wenden
      </p>
      <div class="board-grid">
        {
          vorstand.map((mensch) => (
            <MemberCard
              name={mensch.name}
              role={mensch.funktionen.split('\n')[0]}
              roleDescription={mensch.funktionen
                .split('\n')
                .slice(1)
                .join(', ')}
              image={mensch.foto}
            />
          ))
        }
      </div>
    </div>

    <div class="glass-panel location-section">
      <h2>Hier findest du uns</h2>
      <p>
        Unsere Aufführungen finden meist im <strong>{locationName}</strong> statt.
      </p>

      {
        mapEmbed && (
          <div class="map-container">
            <div class="map-embed" set:html={mapEmbed} />
          </div>
        )
      }
    </div>
  </section>
</Layout>

<style>
  .contact-section {
    max-width: 1000px;
    margin-bottom: 5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .grid-2 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .contact-card,
  .faq-section,
  .board-section,
  .location-section {
    padding: 2.5rem;
  }

  h2 {
    color: var(--accent-green);
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .method {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .method .icon {
    font-size: 1.5rem;
    background: rgba(255, 255, 255, 0.05);
    padding: 0.5rem;
    border-radius: 8px;
    line-height: 1;
  }

  .method div p {
    margin-top: 0.2rem;
  }

  .method a {
    color: var(--text-main);
    text-decoration: none;
    font-size: 1.1rem;
  }

  .method a:hover {
    color: var(--accent-green);
  }

  .contact-card p {
    line-height: 1.6;
  }

  /* Social Links Polishing (Global overrides for Component) */
  :global(.contact-socials) {
    margin-top: 4rem !important;
    gap: 1.5rem !important;
  }

  :global(.contact-socials .social-icon) {
    width: 48px !important;
    height: 48px !important;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  :global(.contact-socials .social-icon svg) {
    width: 24px !important;
    height: 24px !important;
  }

  :global(.contact-socials .social-icon:hover) {
    background: rgba(255, 255, 255, 0.1) !important;
    transform: translateY(-4px);
    border-color: var(--accent-green) !important;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .faq-item h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
    color: var(--text-main);
  }

  .faq-item p {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .section-intro {
    margin-bottom: 2rem;
    color: var(--text-muted);
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .map-container {
    margin-top: 1.5rem;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .map-embed :global(iframe) {
    width: 100% !important;
    height: 350px !important;
    border: 0;
    display: block;
  }
</style>
