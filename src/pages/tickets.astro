---
import Layout from '../layouts/Layout.astro';
import MemberCard from '../components/MemberCard.astro';
import ShareButtons from '../components/ShareButtons.astro';
import directus, { DIRECTUS_URL } from '../lib/directus';
import { readSingleton } from '@directus/sdk';
import { Image } from 'astro:assets';
import GalleryImage from '../components/GalleryImage.astro';
import ImageGallery from '../components/ImageGallery.astro';
import { Ticket, Phone, Calendar, Clock } from '@lucide/astro';

const ticketPromo = await directus.request(
  readSingleton('ticket_promotion', {
    fields: [
      'id',
      'anzeige_modus',
      'titel',
      'vorab_titel',
      'kurzbeschreibung',
      'vorab_text',
      'vorab_bild.*',
      'ticketlotse_link',
      'spielort',
      'telefon_reservierung',
      'termin_1',
      'termin_2',
      'termin_3',
      'termin_4',
      'termin_5',
      'termin_6',
      'autor',
      'genre',
      'preis_erwachsene',
      'preis_jugendliche',
      'map_embed',
      'crew.theatermenschen_id.*',
      'crew.theatermenschen_id.foto.*',
      'crew.rolle',
      'crew.rolle_beschreibung',
      'hauptfoto.*',
      'teaser_fotos.directus_files_id.*',
      'teaser_fotos.sort'
    ]
  })
).catch(() => null);

const anzeigeModus = ticketPromo?.anzeige_modus || 'inaktiv';

// If inactive or no data, redirect to home
if (!ticketPromo || anzeigeModus === 'inaktiv') {
  return Astro.redirect('/');
}

const isPreBooking = anzeigeModus === 'vorab_reservierung';

// Prepare scene photos array (only if not pre-booking)
const scenePhotos = isPreBooking ? [] : (ticketPromo.teaser_fotos || [])
  .sort((a: any, b: any) => (a.sort || 0) - (b.sort || 0))
  .map((item: any) => ({
    src: `${DIRECTUS_URL}/assets/${item.directus_files_id?.id || item.directus_files_id}`,
    width: item.directus_files_id?.width || 1600,
    height: item.directus_files_id?.height || 1200,
    thumbnail: `${DIRECTUS_URL}/assets/${item.directus_files_id?.id || item.directus_files_id}`,
    id: item.directus_files_id?.id || item.directus_files_id
  }));

// Format dates from termin_1..6
const locale = 'de-AT';
const dateFormat: Intl.DateTimeFormatOptions = { 
  day: '2-digit', 
  month: '2-digit', 
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZone: 'Europe/Vienna'
};

const termineArray = [
  ticketPromo.termin_1,
  ticketPromo.termin_2,
  ticketPromo.termin_3,
  ticketPromo.termin_4,
  ticketPromo.termin_5,
  ticketPromo.termin_6
]
  .filter(t => t)
  .map(t => {
    const d = new Date(t);
    return {
      date: d.toLocaleDateString(locale, { day: '2-digit', month: '2-digit', year: 'numeric', timeZone: 'Europe/Vienna' }),
      time: d.toLocaleTimeString(locale, { hour: '2-digit', minute: '2-digit', timeZone: 'Europe/Vienna' }),
      weekday: d.toLocaleDateString(locale, { weekday: 'short', timeZone: 'Europe/Vienna' }).replace('.', '')
    };
  });

const formatPrice = (price: string | undefined) => {
  if (!price) return null;
  const trimmed = price.trim();
  if (trimmed.includes('€')) return trimmed;
  return `${trimmed} €`;
};

const preiseArray = [
  ticketPromo.preis_erwachsene ? { label: 'Erwachsene', value: formatPrice(ticketPromo.preis_erwachsene) } : null,
  ticketPromo.preis_jugendliche ? { label: 'Kinder/Jugendliche', value: formatPrice(ticketPromo.preis_jugendliche) } : null
].filter(p => p);

const autorGenre = isPreBooking ? null : [ticketPromo.autor, ticketPromo.genre].filter(x => x).join(' / ');

// Filter valid cast members from 'crew' (only if not pre-booking)
const castMembers = isPreBooking ? [] : (ticketPromo.crew
  ?.filter((s: any) => s.theatermenschen_id)
  .map((s: any) => ({
    name: s.theatermenschen_id.name,
    rolle: s.rolle,
    rolle_beschreibung: s.rolle_beschreibung,
    foto: s.theatermenschen_id.foto
  })) || []);

// Prepare SEO metadata
const displayTitle = isPreBooking 
  ? (ticketPromo.vorab_titel || ticketPromo.titel) 
  : ticketPromo.titel;
const displayText = isPreBooking 
  ? (ticketPromo.vorab_text || ticketPromo.kurzbeschreibung) 
  : ticketPromo.kurzbeschreibung;
const metaDescription = (displayText || "").length > 160 
  ? displayText.substring(0, 157) + "..." 
  : (displayText || "Sichern Sie sich Tickets für die aktuelle Produktion der Theatergruppe Kleinraming.");
const ogImage = isPreBooking 
  ? (ticketPromo.vorab_bild ? `${DIRECTUS_URL}/assets/${ticketPromo.vorab_bild.id || ticketPromo.vorab_bild}` : undefined)
  : (ticketPromo.hauptfoto ? `${DIRECTUS_URL}/assets/${ticketPromo.hauptfoto.id || ticketPromo.hauptfoto}` : undefined);
---

<Layout 
  title="Karten & Vorstellungen" 
  description={metaDescription}
  image={ogImage}
>
  <div class="container page-header">
    <span class="play-status">
      {isPreBooking ? 'Saison-Vorschau' : 'Nächste Premiere'}
    </span>
    <h1 class="flyer-title">
      {isPreBooking ? (ticketPromo.vorab_titel || ticketPromo.titel) : ticketPromo.titel}
    </h1>
    {autorGenre && <p class="flyer-subtitle">{autorGenre}</p>}
  </div>

  <section class="container flyer-layout">
    <!-- Photo Section -->
    <div class="flyer-photo">
      {isPreBooking ? (
        ticketPromo.vorab_bild && (
          <GalleryImage 
            src={`${DIRECTUS_URL}/assets/${ticketPromo.vorab_bild.id || ticketPromo.vorab_bild}`} 
            alt="Saison Vorschau"
            width={1000}
            aspectRatio="10 / 7"
          />
        )
      ) : (
        ticketPromo.hauptfoto && (
          <GalleryImage 
            src={`${DIRECTUS_URL}/assets/${ticketPromo.hauptfoto.id || ticketPromo.hauptfoto}`} 
            alt="Ensemble"
            width={1000}
            aspectRatio="10 / 7"
          />
        )
      )}
    </div>

    <!-- Booking Sidebar (Mobile: Middle, Desktop: Right) -->
    <div class="flyer-sidebar">
      <div class="glass-panel sticky-box">
        {ticketPromo.ticketlotse_link && (
          <a href={ticketPromo.ticketlotse_link} target="_blank" rel="noopener noreferrer" class="btn btn-large btn-full">
            <Ticket size={24} class="btn-icon" />
            Online reservieren
          </a>
        )}
        
        {ticketPromo.telefon_reservierung && (
          <div class="info-group">
            <h3>Telefonische Reservierung</h3>
            <div class="phone-wrapper">
              <Phone size={24} class="phone-icon" />
              <p class="highlight-text">
                <a href={`tel:${ticketPromo.telefon_reservierung.replace(/^0/, '+43').replace(/[^0-9+]/g, '')}`} class="phone-link">
                  {ticketPromo.telefon_reservierung}
                </a>
              </p>
            </div>
          </div>
        )}

        <ShareButtons title={displayTitle} />

        <hr class="divider" />

        {termineArray.length > 0 && (
          <div class="info-group">
            <h3>Spielzeiten</h3>
            <ul class="dates-list">
              {termineArray.map((termin) => (
                <li>
                  <div class="date-row">
                    <Calendar size={18} class="date-icon" />
                    <span class="date-weekday">{termin.weekday}</span>
                    <span class="date-val">{termin.date}</span>
                  </div>
                  <div class="time-row">
                    <Clock size={16} class="time-icon" />
                    <span>{termin.time} Uhr</span>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}

        <hr class="divider" />

        <div class="info-group">
          <h3>Eintritt</h3>
          {preiseArray.length > 0 ? (
            <ul class="prices-list">
              {preiseArray.map((preis) => (
                <li>
                  <span class="price-label">{preis.label}</span>
                  <span class="price-val">{preis.value}</span>
                </li>
              ))}
            </ul>
          ) : (
            <p>Freiwillige Spende</p>
          )}
        </div>

        {ticketPromo.spielort && (
          <>
            <hr class="divider" />
            <div class="info-group location-group">
              <h3>Spielort</h3>
              <p>{ticketPromo.spielort}</p>
              {ticketPromo.map_embed && (
                <div class="map-container">
                  <div class="map-embed" set:html={ticketPromo.map_embed} />
                </div>
              )}
            </div>
          </>
        )}
      </div>
    </div>

    <!-- Main Content Section -->
    <div class="flyer-content">
      <div class="glass-panel content-box">
        <h2>{isPreBooking ? 'Vorschau auf die Saison' : 'Aus dem Inhalt'}</h2>
        <p class="synopsis-text">
          {isPreBooking 
            ? (ticketPromo.vorab_text || ticketPromo.kurzbeschreibung) 
            : ticketPromo.kurzbeschreibung}
        </p>
      </div>

      {castMembers.length > 0 && (
        <div class="glass-panel cast-box">
          <h2>Die Mitwirkenden</h2>
          <div class="cast-grid">
            {castMembers.map((member: any) => (
              <MemberCard 
                name={member.name}
                role={member.rolle}
                roleDescription={member.rolle_beschreibung}
                image={member.foto}
              />
            ))}
          </div>
        </div>
      )}

      {scenePhotos.length > 0 && (
        <div class="gallery-section">
          <h2>Bilder aus dem Stück</h2>
          <ImageGallery images={scenePhotos} title={displayTitle} />
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .play-status {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(143, 194, 56, 0.2);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(143, 194, 56, 0.3);
    color: var(--accent-green);
    padding: 0.4rem 1.2rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    min-height: 2.2rem; /* Stabilize height for font loading */
    line-height: 1;
  }

  :global([data-theme="light"]) .play-status {
    background: rgba(143, 194, 56, 0.15);
    color: #4a661c; /* Darker green for contrast on light background */
    border-color: rgba(143, 194, 56, 0.4);
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
    min-height: 180px; /* Reserve space for header content */
  }

  .flyer-title {
    color: var(--accent-gold);
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
  }

  .flyer-subtitle {
    font-size: 1.5rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .flyer-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 5rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .flyer-layout {
      grid-template-columns: 1.5fr 1fr;
      grid-template-rows: max-content 1fr;
      gap: 3rem;
    }

    .flyer-photo {
      grid-column: 1;
      grid-row: 1;
    }

    .flyer-sidebar {
      grid-column: 2;
      grid-row: 1 / span 2;
      position: sticky;
      top: 100px;
    }

    .flyer-content {
      grid-column: 1;
      grid-row: 2;
    }
  }

  .flyer-content {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .gallery-section {
    margin-top: 1rem;
  }

  .gallery-section h2 {
    color: var(--accent-green);
    margin-bottom: 2rem;
    font-size: 1.8rem;
  }

  .content-box, .cast-box, .sticky-box {
    padding: 2.5rem;
  }

  .content-box h2, .cast-box h2 {
    color: var(--accent-green);
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
  }

  .synopsis-text {
    font-size: 1.1rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .scene-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
/* Ensemble Photo */

  /* Cast Styles (matching stuecke/[slug].astro) */
  .cast-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .cast-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .cast-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Sticky Sidebar */
  @media (min-width: 900px) {
    .flyer-sidebar {
      position: sticky;
      top: 100px;
    }
  }

  .btn-large {
    font-size: 1.2rem;
    padding: 1.2rem;
    margin-bottom: 2rem;
  }

  .btn-full {
    width: 100%;
    text-align: center;
    display: flex;
  }

  .info-group {
    margin-bottom: 1.5rem;
  }

  .info-group:last-child {
    margin-bottom: 0;
  }

  .info-group h3 {
    color: var(--accent-green);
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .btn-icon {
    margin-right: 0.8rem;
  }

  .phone-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    background: var(--card-bg);
    padding: 1.2rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--card-border);
    transition: var(--transition);
  }

  .phone-wrapper:hover {
    background: var(--card-bg-hover);
    border-color: rgba(var(--text-main-rgb), 0.1);
  }

  .phone-icon {
    color: var(--accent-green);
    flex-shrink: 0;
  }

  .highlight-text {
    font-size: 1.2rem;
    font-weight: bold;
    color: var(--text-main);
  }

  .phone-link {
    color: var(--text-main);
    text-decoration: none;
    transition: var(--transition);
  }

  .phone-link:hover {
    color: var(--accent-green);
  }

  .dates-list, .prices-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .dates-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.8rem 0;
    border-bottom: 1px solid var(--card-border);
  }

  .date-row, .time-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .date-icon, .time-icon {
    color: var(--accent-green);
    opacity: 0.8;
  }

  .date-weekday {
    color: var(--accent-gold);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    min-width: 1.8rem;
  }

  .date-val {
    font-weight: 500;
    color: var(--text-main);
  }

  .time-row {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .prices-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--card-border);
  }

  .price-label {
    color: var(--text-muted);
  }

  .price-val {
    font-weight: 700;
    color: var(--text-main);
  }

  .dates-list li:last-child, .prices-list li:last-child {
    border-bottom: none;
  }

  .divider {
    border: 0;
    height: 1px;
    background: var(--card-border);
    margin: 2rem 0;
  }

  .location-group p {
    margin-bottom: 1rem;
  }

  .map-container {
    aspect-ratio: 16 / 9;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--card-border);
    background-color: var(--card-bg);
    position: relative;
  }

  .map-embed {
    width: 100%;
    height: 100%;
  }

  .map-embed :global(iframe) {
    width: 100% !important;
    height: 100% !important;
    position: absolute;
    top: 0;
    left: 0;
    border: 0;
    display: block;
  }
</style>
