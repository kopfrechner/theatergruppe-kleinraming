---
import Layout from '../layouts/Layout.astro';
import MemberCard from '../components/MemberCard.astro';
import directus, { DIRECTUS_URL } from '../lib/directus';
import { readSingleton } from '@directus/sdk';
import { Image } from 'astro:assets';

const ticketPromo = await directus.request(
  readSingleton('ticket_promotion', {
    fields: [
      'id',
      'aktiv',
      'titel',
      'kurzbeschreibung',
      'ticketlotse_link',
      'spielort',
      'telefon_reservierung',
      'termin_1',
      'termin_2',
      'termin_3',
      'termin_4',
      'termin_5',
      'termin_6',
      'autor',
      'genre',
      'preis_erwachsene',
      'preis_jugendliche',
      'map_embed',
      'crew.theatermenschen_id.*',
      'crew.theatermenschen_id.foto.*',
      'crew.rolle',
      'crew.rolle_beschreibung',
      'hauptfoto.*',
      'foto_szene_1.*',
      'foto_szene_2.*',
      'foto_szene_3.*',
      'foto_szene_4.*'
    ]
  })
).catch(() => null);

// If inactive or no data, you could optionally redirect to home
if (!ticketPromo || !ticketPromo.aktiv) {
  return Astro.redirect('/');
}

// Prepare scene photos array
const scenePhotos = [
  ticketPromo.foto_szene_1,
  ticketPromo.foto_szene_2,
  ticketPromo.foto_szene_3,
  ticketPromo.foto_szene_4
].filter(f => f);

// Format dates from termin_1..6
const locale = 'de-AT';
const dateFormat: Intl.DateTimeFormatOptions = { 
  day: '2-digit', 
  month: '2-digit', 
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit',
  timeZone: 'Europe/Vienna'
};

const termineArray = [
  ticketPromo.termin_1,
  ticketPromo.termin_2,
  ticketPromo.termin_3,
  ticketPromo.termin_4,
  ticketPromo.termin_5,
  ticketPromo.termin_6
]
  .filter(t => t)
  .map(t => new Date(t).toLocaleString(locale, dateFormat) + ' Uhr');

const formatPrice = (price: string | undefined) => {
  if (!price) return null;
  const trimmed = price.trim();
  if (trimmed.includes('€')) return trimmed;
  return `${trimmed} €`;
};

const preiseArray = [
  ticketPromo.preis_erwachsene ? `Erwachsene: ${formatPrice(ticketPromo.preis_erwachsene)}` : null,
  ticketPromo.preis_jugendliche ? `Kinder/Jugendliche: ${formatPrice(ticketPromo.preis_jugendliche)}` : null
].filter(p => p);

const autorGenre = [ticketPromo.autor, ticketPromo.genre].filter(x => x).join(' / ');

// Filter valid cast members from 'crew'
const castMembers = ticketPromo.crew
  ?.filter((s: any) => s.theatermenschen_id)
  .map((s: any) => ({
    name: s.theatermenschen_id.name,
    rolle: s.rolle,
    rolle_beschreibung: s.rolle_beschreibung,
    foto: s.theatermenschen_id.foto
  })) || [];
---

<Layout title="Karten & Vorstellungen">
  <div class="container page-header">
    <span class="play-status">Nächste Premiere</span>
    <h1 class="flyer-title">{ticketPromo.titel}</h1>
    {autorGenre && <p class="flyer-subtitle">{autorGenre}</p>}
  </div>

  <section class="container flyer-layout">
    <!-- Left Column: Content and Cast -->
    <div class="flyer-main">
      {ticketPromo.hauptfoto && (
        <div class="ensemble-photo">
          <Image 
            src={`${DIRECTUS_URL}/assets/${ticketPromo.hauptfoto.id || ticketPromo.hauptfoto}`} 
            alt="Ensemble"
            width={1000}
            height={700}
            format="webp"
          />
        </div>
      )}

      <div class="glass-panel content-box">
        <h2>Aus dem Inhalt</h2>
        <p class="synopsis-text">{ticketPromo.kurzbeschreibung}</p>
      </div>

      {castMembers.length > 0 && (
        <div class="glass-panel cast-box">
          <h2>Die Mitwirkenden</h2>
          <div class="cast-grid">
            {castMembers.map((member: any) => (
              <MemberCard 
                name={member.name}
                role={member.rolle}
                roleDescription={member.rolle_beschreibung}
                image={member.foto}
              />
            ))}
          </div>
        </div>
      )}

      {scenePhotos.length > 0 && (
        <div class="scene-grid">
          {scenePhotos.map((foto: any) => (
            <div class="scene-item">
              <Image 
                src={`${DIRECTUS_URL}/assets/${foto.id || foto}`} 
                alt="Szenenfoto"
                width={400}
                height={300}
                format="webp"
              />
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Right Column: Sticky Booking Box -->
    <div class="flyer-sidebar">
      <div class="glass-panel sticky-box">
        {ticketPromo.ticketlotse_link && (
          <a href={ticketPromo.ticketlotse_link} target="_blank" rel="noopener noreferrer" class="btn btn-large btn-full">
            Tickets reservieren
          </a>
        )}
        
        {ticketPromo.telefon_reservierung && (
          <div class="info-group">
            <h3>Telefonische Reservierung</h3>
            <p class="highlight-text">
              <a href={`tel:${ticketPromo.telefon_reservierung.replace(/^0/, '+43').replace(/[^0-9+]/g, '')}`} class="phone-link">
                {ticketPromo.telefon_reservierung}
              </a>
            </p>
          </div>
        )}

        <hr class="divider" />

        {termineArray.length > 0 && (
          <div class="info-group">
            <h3>Spielzeiten</h3>
            <ul class="dates-list">
              {termineArray.map((termin: string) => (
                <li>{termin}</li>
              ))}
            </ul>
          </div>
        )}

        <hr class="divider" />

        <div class="info-group">
          <h3>Eintritt</h3>
          {preiseArray.length > 0 ? (
            <ul class="prices-list">
              {preiseArray.map((preis: string) => (
                <li>{preis}</li>
              ))}
            </ul>
          ) : (
            <p>Freiwillige Spende</p>
          )}
        </div>

        {ticketPromo.spielort && (
          <>
            <hr class="divider" />
            <div class="info-group location-group">
              <h3>Spielort</h3>
              <p>{ticketPromo.spielort}</p>
              {ticketPromo.map_embed && (
                <div class="map-container">
                  <div class="map-embed" set:html={ticketPromo.map_embed} />
                </div>
              )}
            </div>
          </>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .play-status {
    display: inline-block;
    background: rgba(143, 194, 56, 0.15);
    color: var(--accent-green);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .flyer-title {
    color: var(--accent-gold);
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
  }

  .flyer-subtitle {
    font-size: 1.5rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .flyer-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 5rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .flyer-layout {
      grid-template-columns: 1.5fr 1fr;
      gap: 3rem;
    }
  }

  .flyer-main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-box, .cast-box, .sticky-box {
    padding: 2.5rem;
  }

  .content-box h2, .cast-box h2 {
    color: var(--accent-green);
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
  }

  .synopsis-text {
    font-size: 1.1rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  /* Scene Grid */
  .scene-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .scene-item {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .scene-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Ensemble Photo */
  .ensemble-photo {
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .ensemble-photo img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Cast Styles (matching stuecke/[slug].astro) */
  .cast-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 600px) {
    .cast-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Sticky Sidebar */
  @media (min-width: 900px) {
    .flyer-sidebar {
      position: sticky;
      top: 100px;
    }
  }

  .btn-large {
    font-size: 1.2rem;
    padding: 1.2rem;
    margin-bottom: 2rem;
  }

  .btn-full {
    width: 100%;
    text-align: center;
    display: flex;
  }

  .info-group {
    margin-bottom: 1.5rem;
  }

  .info-group:last-child {
    margin-bottom: 0;
  }

  .info-group h3 {
    color: var(--accent-green);
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .highlight-text {
    font-size: 1.4rem;
    font-weight: bold;
    color: var(--text-main);
  }

  .phone-link {
    color: inherit;
    text-decoration: none;
    transition: var(--transition);
  }

  .phone-link:hover {
    color: var(--accent-green);
  }

  .dates-list, .prices-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .dates-list li, .prices-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dates-list li:last-child, .prices-list li:last-child {
    border-bottom: none;
  }

  .divider {
    border: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 2rem 0;
  }

  .location-group p {
    margin-bottom: 1rem;
  }

  .map-container {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .map-embed :global(iframe) {
    width: 100% !important;
    height: 250px !important;
    border: 0;
    display: block;
  }
</style>
