---
import Layout from '../layouts/Layout.astro';
import directus from '../lib/directus';
import { readSingleton } from '@directus/sdk';
import { Image } from 'astro:assets';

const ticketPromo = await directus.request(
  readSingleton('ticket_promotion', {
    fields: [
      '*',
      'crew.theatermenschen_id.*',
      'crew.rolle'
    ]
  })
).catch(() => null);

// If inactive or no data, you could optionally redirect to home
if (!ticketPromo || !ticketPromo.aktiv) {
  return Astro.redirect('/');
}

// Format dates from termin_1..6
const locale = 'de-AT';
const dateFormat: Intl.DateTimeFormatOptions = { 
  day: '2-digit', 
  month: '2-digit', 
  year: 'numeric',
  hour: '2-digit',
  minute: '2-digit'
};

const termineArray = [
  ticketPromo.termin_1,
  ticketPromo.termin_2,
  ticketPromo.termin_3,
  ticketPromo.termin_4,
  ticketPromo.termin_5,
  ticketPromo.termin_6
]
  .filter(t => t)
  .map(t => new Date(t).toLocaleString(locale, dateFormat) + ' Uhr');

const preiseArray = [
  ticketPromo.preis_erwachsene ? `Erwachsene: ${ticketPromo.preis_erwachsene}` : null,
  ticketPromo.preis_jugendliche ? `Kinder/Jugendliche: ${ticketPromo.preis_jugendliche}` : null
].filter(p => p);

const autorGenre = [ticketPromo.autor, ticketPromo.genre].filter(x => x).join(' / ');

// Filter valid cast members from 'crew'
const castMembers = ticketPromo.crew
  ?.filter((s: any) => s.theatermenschen_id)
  .map((s: any) => ({
    name: s.theatermenschen_id.name,
    rolle: s.rolle,
    foto: s.theatermenschen_id.foto
  })) || [];
---

<Layout title="Karten & Vorstellungen">
  <div class="container page-header">
    <span class="play-status">Nächste Premiere</span>
    <h1 class="flyer-title">{ticketPromo.titel}</h1>
    {autorGenre && <p class="flyer-subtitle">{autorGenre}</p>}
  </div>

  <section class="container flyer-layout">
    <!-- Left Column: Content and Cast -->
    <div class="flyer-main">
      <div class="glass-panel content-box">
        <h2>Aus dem Inhalt</h2>
        <p class="synopsis-text">{ticketPromo.kurzbeschreibung}</p>
      </div>

      {castMembers.length > 0 && (
        <div class="glass-panel cast-box">
          <h2>Die Mitwirkenden</h2>
          <div class="cast-grid">
            {castMembers.map((member: any) => (
              <div class="cast-member">
                <div class="member-info">
                  <span class="member-role">{member.rolle}</span>
                  <span class="member-name">{member.name}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>

    <!-- Right Column: Sticky Booking Box -->
    <div class="flyer-sidebar">
      <div class="glass-panel sticky-box">
        {ticketPromo.ticketlotse_link && (
          <a href={ticketPromo.ticketlotse_link} target="_blank" rel="noopener noreferrer" class="btn btn-large btn-full">
            Tickets reservieren
          </a>
        )}
        
        {ticketPromo.telefon_reservierung && (
          <div class="info-group">
            <h3>Telefonische Reservierung</h3>
            <p class="highlight-text">{ticketPromo.telefon_reservierung}</p>
          </div>
        )}

        <hr class="divider" />

        {termineArray.length > 0 && (
          <div class="info-group">
            <h3>Spielzeiten</h3>
            <ul class="dates-list">
              {termineArray.map((termin: string) => (
                <li>{termin}</li>
              ))}
            </ul>
          </div>
        )}

        <hr class="divider" />

        <div class="info-group">
          <h3>Eintritt</h3>
          {preiseArray.length > 0 ? (
            <ul class="prices-list">
              {preiseArray.map((preis: string) => (
                <li>{preis}</li>
              ))}
            </ul>
          ) : (
            <p>Freiwillige Spende</p>
          )}
        </div>

        {ticketPromo.spielort && (
          <>
            <hr class="divider" />
            <div class="info-group">
              <h3>Spielort</h3>
              <p>{ticketPromo.spielort}</p>
            </div>
          </>
        )}
      </div>
    </div>
  </section>
</Layout>

<style>
  .play-status {
    display: inline-block;
    background: rgba(143, 194, 56, 0.15);
    color: var(--accent-green);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .page-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .flyer-title {
    color: var(--accent-gold);
    font-size: 3.5rem;
    margin-bottom: 0.5rem;
  }

  .flyer-subtitle {
    font-size: 1.5rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .flyer-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-bottom: 5rem;
    align-items: start;
  }

  @media (min-width: 900px) {
    .flyer-layout {
      grid-template-columns: 1.5fr 1fr;
      gap: 3rem;
    }
  }

  .flyer-main {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .content-box, .cast-box, .sticky-box {
    padding: 2.5rem;
  }

  .content-box h2, .cast-box h2 {
    color: var(--accent-green);
    margin-bottom: 1.5rem;
    font-size: 1.8rem;
  }

  .synopsis-text {
    font-size: 1.1rem;
    line-height: 1.7;
    white-space: pre-wrap;
  }

  .cast-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 600px) {
    .cast-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cast-member {
    background: rgba(255, 255, 255, 0.03);
    padding: 1rem;
    border-radius: var(--radius-md);
    border-left: 3px solid var(--accent-gold);
  }

  .member-info {
    display: flex;
    flex-direction: column;
  }

  .member-role {
    color: var(--accent-gold);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.2rem;
  }

  .member-name {
    font-size: 1.1rem;
    font-weight: 600;
  }

  /* Sticky Sidebar */
  @media (min-width: 900px) {
    .flyer-sidebar {
      position: sticky;
      top: 100px;
    }
  }

  .btn-large {
    font-size: 1.2rem;
    padding: 1.2rem;
    margin-bottom: 2rem;
  }

  .btn-full {
    width: 100%;
    text-align: center;
    display: block;
  }

  .info-group {
    margin-bottom: 1.5rem;
  }

  .info-group:last-child {
    margin-bottom: 0;
  }

  .info-group h3 {
    color: var(--accent-green);
    font-size: 1.1rem;
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .highlight-text {
    font-size: 1.4rem;
    font-weight: bold;
    color: var(--text-main);
  }

  .dates-list, .prices-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .dates-list li, .prices-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .dates-list li:last-child, .prices-list li:last-child {
    border-bottom: none;
  }

  .divider {
    border: 0;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 2rem 0;
  }
</style>
