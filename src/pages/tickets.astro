---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Karten & Vorstellungen">
  <div class="container page-header">
    <h1>Karten & Vorstellungen</h1>
    <p class="subtitle">Sichern Sie sich hier Ihre Tickets für unsere kommenden Aufführungen.</p>
  </div>

  <section class="container ticket-section">
    <div class="glass-panel ticket-container">
      <h2>Aktuelles Stück: "Der zerbrochne Krug"</h2>
      <p>Hier können Sie direkt Ihre Tickets buchen.</p>
      
      <!-- Platzhalter für Ticketlotse iFrame -->
      <div class="iframe-placeholder">
        <p class="iframe-note">Ticketlotse iFrame wird hier geladen</p>
        <!-- Später: <iframe src="https://ticketlotse.de/..." width="100%" height="600" frameborder="0"></iframe> -->
      </div>
    </div>
  </section>
</Layout>

<style>
  .subtitle {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 1rem auto 0;
  }

  .ticket-section {
    max-width: 800px;
    margin-bottom: 5rem;
  }

  .ticket-container {
    padding: 3rem;
    text-align: center;
  }

  .ticket-container h2 {
    color: var(--accent-green);
  }

  .iframe-placeholder {
    margin-top: 2rem;
    background-color: var(--bg-color);
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .iframe-note {
    color: var(--text-muted);
    font-family: monospace;
  }
</style>
