---
import Layout from '../layouts/Layout.astro';
import directus from '../lib/directus';
import { readItems } from '@directus/sdk';
import { Image } from 'astro:assets';

const sponsors = await directus.request(
  readItems('sponsoren', {
    fields: ['id', 'unternehmen', 'link', 'bild.*'],
    sort: ['unternehmen']
  })
);

const DIRECTUS_URL = 'https://cms.kopfarbeit.dev';
---

<Layout title="Sponsoren">
  <div class="container page-header">
    <h1>Unsere Sponsoren</h1>
    <p class="subtitle">Vielen Dank für die Unterstützung unserer Theatergruppe.</p>
  </div>

  <section class="container sponsoren-section">
    <div class="grid sponsoren-grid">
      {sponsors.map(sponsor => (
        <a href={sponsor.link || '#'} target="_blank" rel="noopener noreferrer" class={`glass-panel sponsor-card ${!sponsor.link ? 'no-link' : ''}`}>
          <div class="sponsor-logo-placeholder">
            {sponsor.bild ? (
              <Image 
                src={`${DIRECTUS_URL}/assets/${sponsor.bild.id}`} 
                alt={sponsor.unternehmen}
                width={400}
                height={Math.round(400 * (sponsor.bild.height / sponsor.bild.width))}
                format="webp"
              />
            ) : (
              <div class="no-logo">Kein Logo verfügbar</div>
            )}
          </div>
          <div class="sponsor-info">
            <h3>{sponsor.unternehmen}</h3>
          </div>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 3rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 1rem auto;
  }

  .sponsoren-section {
    margin-bottom: 5rem;
  }

  .sponsoren-grid {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    justify-content: center;
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .sponsor-card {
    text-align: center;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .sponsor-card:hover:not(.no-link) {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
    border-color: var(--accent-green);
  }

  .no-link {
    cursor: default;
  }

  .sponsor-logo-placeholder {
    height: 180px;
    background-color: #fff; /* Logos often have white backgrounds */
    padding: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .sponsor-logo-placeholder img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .no-logo {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #666;
    font-size: 0.8rem;
  }

  .sponsor-info {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--bg-color-light);
  }

  .sponsor-info h3 {
    margin: 0;
    font-size: 1.1rem;
    color: var(--text-color);
  }

  .sponsor-card:hover .sponsor-info h3 {
    color: var(--accent-green);
  }
</style>
