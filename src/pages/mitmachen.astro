---
import Layout from '../layouts/Layout.astro';
import { Users, Construction, Paintbrush, Utensils, Heart, Sparkles, Smile } from '@lucide/astro';
---

<Layout title="Mitmachen">
  <div class="container page-header">
    <h1>Werde Teil der Theatergruppe</h1>
    <p class="subtitle">Wir suchen immer motivierte Leute für die Bühne und dahinter!</p>
  </div>

  <section class="container join-section">
    <div class="glass-panel content-box">
      <div class="grid grid-2">
        <div>
          <h2>Warum Mitmachen?</h2>
          <ul class="icon-list">
            <li><Heart class="text-green" size={20} /> Tolle Gemeinschaft und Zusammenhalt</li>
            <li><Sparkles class="text-green" size={20} /> Gemeinsam kreative Projekte umsetzen</li>
            <li><Smile class="text-green" size={20} /> Viel Spaß bei Proben und Aufführungen</li>
          </ul>
        </div>
        <div>
          <h2>Welche Rollen gibt es?</h2>
          <ul class="icon-list">
            <li><Users class="text-green" size={20} /> Schauspiel: Steh im Rampenlicht!</li>
            <li><Construction class="text-green" size={20} /> Bühnenbau & Technik: Bastler und Tüftler.</li>
            <li><Paintbrush class="text-green" size={20} /> Maske & Kostüm: Kreativität gefragt.</li>
            <li><Utensils class="text-green" size={20} /> Gastro & Kassa: Das Team am Abend.</li>
          </ul>
        </div>
      </div>

      <div class="contact-box">
        <h3>Interessiert?</h3>
        <p>Melde dich bei uns! Wir freuen uns auf dich.</p>
        <a href="/kontakt" class="btn">Kontakt aufnehmen</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .join-section {
    max-width: 900px;
    margin-bottom: 5rem;
  }

  .content-box {
    padding: 3rem;
  }

  .grid-2 {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .grid-2 h2 {
    color: var(--accent-green);
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .icon-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .icon-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-main);
  }

  .text-green {
    color: var(--accent-green);
    flex-shrink: 0;
  }

  .contact-box {
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 3rem;
  }

  .contact-box h3 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .contact-box p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
</style>
