---
import Layout from '../layouts/Layout.astro';
import {
  Users,
  Construction,
  Paintbrush,
  Utensils,
  Heart,
  Sparkles,
  Smile,
  ArrowRight,
} from '@lucide/astro';
---

<Layout
  title="Mitwirken"
  description="Werde Teil der Theatergruppe Kleinraming. Wir suchen immer motivierte Menschen für die Bühne und dahinter – vom Schauspiel bis zur Technik."
>
  <div class="container page-header">
    <h1>Werde Teil der Theatergruppe</h1>
    <p class="subtitle">
      Wir suchen immer motivierte Leute für die Bühne und dahinter!
    </p>
  </div>

  <section class="container join-section">
    <!-- Warum Mitwirken Banner -->
    <div class="glass-panel feature-banner">
      <h2>Warum Mitwirken?</h2>
      <div class="benefits-grid">
        <div class="benefit-item">
          <div class="icon-wrapper">
            <Heart size={28} />
          </div>
          <p>Tolle Gemeinschaft und ein starker Zusammenhalt</p>
        </div>
        <div class="benefit-item">
          <div class="icon-wrapper">
            <Sparkles size={28} />
          </div>
          <p>Gemeinsam kreative Projekte von Null aufbauen</p>
        </div>
        <div class="benefit-item">
          <div class="icon-wrapper">
            <Smile size={28} />
          </div>
          <p>Riesiger Spaß bei den Proben und nach Aufführungen</p>
        </div>
      </div>
    </div>

    <!-- Rollen Grid -->
    <div class="section-title-wrapper">
      <h2>Welche Rollen gibt es?</h2>
      <p class="text-muted">Jedes Talent findet bei uns seinen Platz.</p>
    </div>

    <div class="roles-grid">
      <div class="glass-panel role-card">
        <Users class="role-icon" size={40} stroke-width={1.5} />
        <h3>Schauspiel</h3>
        <p>
          Du liebst es, in andere Rollen zu schlüpfen? Steh bei uns im
          Rampenlicht und begeistere das Publikum.
        </p>
      </div>

      <div class="glass-panel role-card">
        <Construction class="role-icon" size={40} stroke-width={1.5} />
        <h3>Bühnenbau & Technik</h3>
        <p>
          Für Bastler, Tüftler und Handwerker. Wir bauen unsere Kulissen selbst
          und sorgen für das perfekte Licht.
        </p>
      </div>

      <div class="glass-panel role-card">
        <Paintbrush class="role-icon" size={40} stroke-width={1.5} />
        <h3>Maske & Kostüm</h3>
        <p>
          Kreativität ist hier gefragt. Verwandle unsere Darsteller optisch in
          die Charaktere, die sie spielen.
        </p>
      </div>

      <div class="glass-panel role-card">
        <Utensils class="role-icon" size={40} stroke-width={1.5} />
        <h3>Gastro & Kassa</h3>
        <p>
          Das wichtigste Team am Abend. Sorge dafür, dass unsere Gäste bestens
          versorgt sind und sich wohlfühlen.
        </p>
      </div>
    </div>

    <!-- CTA Box -->
    <div class="glass-panel cta-box">
      <div class="cta-content">
        <h3>Bereit für dein erstes Projekt?</h3>
        <p>
          Egal ob du schon Erfahrung hast oder kompletter Neuling bist – melde
          dich unverbindlich bei uns! Wir beißen nicht (außer es steht im
          Skript).
        </p>
      </div>
      <a href="/kontakt" class="btn btn-large cta-btn">
        Kontakt aufnehmen <ArrowRight size={20} />
      </a>
    </div>
  </section>
</Layout>

<style>
  .join-section {
    max-width: 1000px;
    margin-bottom: 6rem;
  }

  /* Feature Banner */
  .feature-banner {
    padding: 3rem;
    margin-bottom: 4rem;
    text-align: center;
    background: linear-gradient(
      135deg,
      rgba(var(--bg-color-rgb), 0.4) 0%,
      rgba(143, 194, 56, 0.05) 100%
    );
  }

  .feature-banner h2 {
    color: var(--accent-gold);
    margin-bottom: 2rem;
    font-size: 2rem;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .benefits-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .benefit-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .icon-wrapper {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(143, 194, 56, 0.1);
    color: var(--accent-green);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(143, 194, 56, 0.2);
  }

  .icon-wrapper svg {
    width: 28px;
    height: 28px;
  }

  .benefit-item p {
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--text-main);
  }

  /* Roles Grid */
  .section-title-wrapper {
    text-align: center;
    margin-bottom: 2rem;
  }

  .section-title-wrapper h2 {
    font-size: 2rem;
    color: var(--accent-green);
    margin-bottom: 0.5rem;
  }

  .roles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 600px) {
    .roles-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .role-card {
    padding: 2.5rem 2rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .role-card:hover {
    transform: translateY(-5px);
    border-color: rgba(143, 194, 56, 0.3);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .role-icon {
    width: 40px;
    height: 40px;
    color: var(--accent-gold);
    margin-bottom: 1.5rem;
    transition: transform 0.3s ease;
  }

  .role-card:hover .role-icon {
    transform: scale(1.1);
  }

  .role-card h3 {
    font-size: 1.4rem;
    margin-bottom: 1rem;
    color: var(--text-main);
  }

  .role-card p {
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* CTA Box */
  .cta-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 4rem 2rem;
    gap: 2rem;
    position: relative;
    overflow: hidden;
  }

  .cta-box::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 200px;
    height: 200px;
    background: var(--accent-green);
    filter: blur(100px);
    opacity: 0.15;
    z-index: 0;
    pointer-events: none;
  }

  .cta-content {
    z-index: 1;
    max-width: 600px;
  }

  .cta-content h3 {
    font-size: 2.2rem;
    color: var(--text-main);
    margin-bottom: 1rem;
  }

  .cta-content p {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .cta-btn {
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cta-btn svg {
    width: 20px;
    height: 20px;
  }

  @media (min-width: 768px) {
    .cta-box {
      flex-direction: row;
      text-align: left;
      justify-content: space-between;
      padding: 4rem;
    }

    .cta-content {
      margin-bottom: 0;
    }

    .cta-btn {
      flex-shrink: 0;
    }
  }
</style>
