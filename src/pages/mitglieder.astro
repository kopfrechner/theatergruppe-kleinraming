---
import Layout from '../layouts/Layout.astro';

// Dummy data mock - later replace with Strapi fetch
const members = [
  { name: "Daniela Baumann", role: "Obfrau & Regie", category: "board" },
  { name: "Werner Seirlehner", role: "Schriftführer & Technik", category: "board" },
  { name: "Adolf Seirlehner", role: "Kassier", category: "board" },
  { name: "Gottfried Kopf", role: "Obfrau Stv. & Bühnenbau", category: "board", profile: "Baut detailreiche Bühnenbilder." },
  { name: "Zäzilia Rosenegger", role: "Schriftführerin Stv. & Spielerin", category: "actor" },
  { name: "Reinhard Streitner", role: "Kassier Stv. & Spieler", category: "actor" }
];

const boardMembers = members.filter(m => m.category === "board");
const actors = members.filter(m => m.category === "actor");
const others = members.filter(m => m.category === "other");
---

<Layout title="Mitglieder">
  <div class="container page-header">
    <h1>Unsere Mitglieder</h1>
    <p class="subtitle">Das Team vor und hinter den Kulissen.</p>
  </div>

  <section class="container members-section">
    <h2 class="category-title">Der Vorstand</h2>
    <div class="grid members-grid">
      {boardMembers.map(member => (
        <article class="glass-panel member-card">
          <div class="member-photo-placeholder"></div>
          <div class="member-info">
            <h3>{member.name}</h3>
            <p class="member-role">{member.role}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container members-section">
    <h2 class="category-title">Schauspieler</h2>
    <div class="grid members-grid">
      {actors.map(member => (
        <article class="glass-panel member-card">
          <div class="member-photo-placeholder"></div>
          <div class="member-info">
            <h3>{member.name}</h3>
            <p class="member-role">{member.role}</p>
            {member.profile && <p class="member-profile">{member.profile}</p>}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="container members-section">
    <h2 class="category-title">Hinter den Kulissen</h2>
    <div class="grid members-grid">
      {others.map(member => (
        <article class="glass-panel member-card">
          <div class="member-photo-placeholder"></div>
          <div class="member-info">
            <h3>{member.name}</h3>
            <p class="member-role">{member.role}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .subtitle {
    color: var(--text-muted);
    font-size: 1.2rem;
    max-width: 600px;
    margin: 1rem auto;
  }

  .members-section {
    margin-bottom: 4rem;
  }

  .category-title {
    color: var(--accent-green);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.5rem;
    margin-bottom: 2rem;
  }

  .members-grid {
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 2rem;
  }

  .member-card {
    text-align: center;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .member-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.4);
  }

  .member-photo-placeholder {
    height: 250px;
    background-color: var(--bg-color-light);
    border-bottom: 2px solid var(--accent-green);
  }

  .member-info {
    padding: 1.5rem;
  }

  .member-role {
    color: var(--text-muted);
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .member-profile {
    font-size: 0.85rem;
    margin-top: 1rem;
    color: #ccc;
  }
</style>
