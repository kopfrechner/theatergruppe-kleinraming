---
import Layout from '../../layouts/Layout.astro';
import directus from '../../lib/directus';
import { readItems } from '@directus/sdk';
import { Image } from 'astro:assets';

const stuecke = await directus.request(
  readItems('stuecke', {
    filter: {
      status: { _eq: 'published' }
    },
    sort: ['-auffuehrung_im_jahr']
  })
);

const DIRECTUS_URL = 'https://cms.kopfarbeit.dev';
---

<Layout title="Bisherige Stücke">
  <div class="container page-header">
    <h1>Bisherige Stücke</h1>
    <p class="subtitle">Ein Rückblick auf vergangene Aufführungen.</p>
  </div>

  <section class="container plays-section">
    <div class="grid play-grid">
      {stuecke && stuecke.length > 0 ? (
        stuecke.map(stueck => (
          <article class="glass-panel play-card">
            <div class="play-poster-placeholder">
              {stueck.titelfoto && (
                <Image 
                  src={`${DIRECTUS_URL}/assets/${stueck.titelfoto}`} 
                  alt={stueck.titel} 
                  width={600}
                  height={338}
                  format="webp"
                />
              )}
            </div>
            <div class="play-content">
              <h2>{stueck.titel}</h2>
              <p class="play-year">{stueck.auffuehrung_im_jahr}</p>
              <a href={`/stuecke/${stueck.id}`} class="btn btn-outline" style="width:100%; text-align:center;">Details ansehen</a>
            </div>
          </article>
        ))
      ) : (
        <div class="glass-panel" style="grid-column: 1 / -1; padding: 4rem; text-align: center;">
          <p class="subtitle">Noch keine Stücke vorhanden.</p>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 1rem;">
            Sobald du in Directus ein Stück veröffentlichst, erscheint es hier.
          </p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    margin-bottom: 3rem;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.2rem;
  }

  .plays-section {
    margin-bottom: 5rem;
  }

  .play-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    justify-content: center;
    max-width: 1100px;
    margin: 0 auto;
  }

  .play-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    max-width: 360px;
    margin: 0 auto;
    width: 100%;
  }

  .play-poster-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: var(--bg-color-light);
    overflow: hidden;
  }

  .play-poster-placeholder img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .play-content {
    padding: 1.2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .play-content h2 {
    font-size: 1.2rem;
    margin: 0;
    line-height: 1.3;
  }

  .play-year {
    color: var(--accent-green);
    font-size: 0.9rem;
    margin: 0;
  }

  .btn-outline {
    margin-top: 1rem;
    padding: 0.6rem;
    font-size: 0.9rem;
  }
</style>
