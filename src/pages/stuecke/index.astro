---
import Layout from '../../layouts/Layout.astro';
import fetchApi from '../../lib/strapi';
import type Stueck from '../../interfaces/stueck';

const stuecke = await fetchApi<Stueck[]>({
  endpoint: 'stuecke?populate=vorschaubild',
  wrappedByKey: 'data',
});
---

<Layout title="Bisherige Stücke">
  <div class="container page-header">
    <h1>Bisherige Stücke</h1>
    <p class="subtitle">Ein Rückblick auf vergangene Aufführungen.</p>
  </div>

  <section class="container plays-section">
    <div class="grid play-grid">
      {stuecke && stuecke.length > 0 ? (
        stuecke.map(stueck => (
          <article class="glass-panel play-card">
            <div class="play-poster-placeholder">
              {stueck.vorschaubild && (
                <img src={`${import.meta.env.STRAPI_URL}${stueck.vorschaubild.url}`} alt={stueck.titel} />
              )}
            </div>
            <div class="play-content">
              <h2>{stueck.titel}</h2>
              <p class="play-year">{stueck.jahr}</p>
              <a href={`/stuecke/${stueck.slug}`} class="btn btn-outline" style="width:100%; text-align:center;">Details ansehen</a>
            </div>
          </article>
        ))
      ) : (
        <div class="glass-panel" style="grid-column: 1 / -1; padding: 4rem; text-align: center;">
          <p class="subtitle">Noch keine Stücke vorhanden.</p>
          <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 1rem;">
            Sobald du in Strapi ein Stück veröffentlichst, erscheint es hier.
          </p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .subtitle {
    color: var(--text-muted);
    font-size: 1.2rem;
  }

  .plays-section {
    margin-bottom: 5rem;
  }

  .play-grid {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }

  .play-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .play-poster-placeholder {
    height: 400px;
    background-color: var(--bg-color-light);
  }

  .play-content {
    padding: 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .play-content h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .play-year {
    color: var(--accent-green);
    margin-bottom: 2rem;
    flex: 1;
  }
</style>
