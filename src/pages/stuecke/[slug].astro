---
import Layout from '../../layouts/Layout.astro';
import fetchApi from '../../lib/strapi';
import type Stueck from '../../interfaces/stueck';

export async function getStaticPaths() {
  const stuecke = await fetchApi<Stueck[]>({
    endpoint: 'stuecke?populate=*',
    wrappedByKey: 'data',
  });

  return stuecke.map((stueck) => ({
    params: { slug: stueck.slug },
    props: { stueck },
  }));
}

const { stueck } = Astro.props;
---

<Layout title={stueck.titel}>
  <div class="container page-header">
    <a href="/stuecke" class="back-link">&larr; Zurück zur Übersicht</a>
    <h1>{stueck.titel}</h1>
    <p class="play-year">Aufgeführt: {stueck.jahr}</p>
  </div>

  <section class="container play-detail">
    <div class="glass-panel content-box">
      <h2>Zusammenfassung</h2>
      <div class="abstract">
        {stueck.beschreibung ? (
          <div set:html={stueck.beschreibung} />
        ) : (
          <p>Keine Beschreibung verfügbar.</p>
        )}
      </div>
      
      {stueck.galerie && stueck.galerie.length > 0 && (
        <div class="gallery">
          <h3>Galerie</h3>
          <div class="grid grid-3">
            {stueck.galerie.map(img => (
              <img src={`${import.meta.env.STRAPI_URL}${img.url}`} alt={img.alternativeText || stueck.titel} />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent-green);
  }

  .play-year {
    color: var(--accent-green);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .play-detail {
    max-width: 800px;
    margin-bottom: 5rem;
  }

  .content-box {
    padding: 3rem;
  }

  .abstract {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .gallery-placeholder {
    margin-top: 3rem;
    padding: 3rem;
    background-color: var(--bg-color);
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
    text-align: center;
    color: var(--text-muted);
  }
</style>
