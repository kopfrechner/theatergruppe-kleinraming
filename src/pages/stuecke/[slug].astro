---
import Layout from '../../layouts/Layout.astro';
import CastSection from '../../components/CastSection.astro';
import PlayGallery from '../../components/PlayGallery.astro';
import directus, { DIRECTUS_URL } from '../../lib/directus';
import { readItems } from '@directus/sdk';
import { prepareGalleryImages } from '../../lib/mappers';

export async function getStaticPaths() {
  const stuecke = await directus.request(
    readItems('stuecke', {
      filter: {
        status: { _eq: 'published' }
      },
      fields: ['*', 'foto_gallerie.*', 'spieler.*', 'spieler.theatermenschen_id.*', 'spieler.theatermenschen_id.foto.*'],
      deep: {
        foto_gallerie: {
          _sort: ['sort']
        },
        spieler: {
          _sort: ['sort']
        }
      }
    })
  );

  return stuecke.map((stueck) => ({
    params: { slug: stueck.slug || stueck.id },
    props: { stueck },
  }));
}

const { stueck } = Astro.props;

const filteredGallery = await prepareGalleryImages(stueck.foto_gallerie, DIRECTUS_URL);
---

<Layout title={stueck.titel}>
  <div class="container page-header">
    <a href="/stuecke" class="back-link">&larr; Zurück zur Übersicht</a>
    <h1>{stueck.titel}</h1>
    <p class="play-year">Aufgeführt: {stueck.auffuehrung_im_jahr}</p>
  </div>

  <section class="container play-detail">
    <div class="glass-panel content-box">
      <h2>Zusammenfassung</h2>
      <div class="abstract">
        {stueck.synopsis ? (
          <div set:html={stueck.synopsis} />
        ) : (
          <p>Keine Beschreibung verfügbar.</p>
        )}
      </div>
      
      {stueck.spieler && stueck.spieler.length > 0 && (
        <CastSection spieler={stueck.spieler} />
      )}

      {filteredGallery.length > 0 && (
        <PlayGallery images={filteredGallery} title={stueck.titel} />
      )}
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent-gold);
  }

  .play-year {
    color: var(--accent-gold);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .play-detail {
    max-width: 1000px;
    margin-bottom: 5rem;
  }

  .content-box {
    padding: 3rem;
  }

  .abstract {
    font-size: 1.1rem;
    line-height: 1.8;
  }
</style>