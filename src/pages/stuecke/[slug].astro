---
import Layout from '../../layouts/Layout.astro';
import directus from '../../lib/directus';
import { readItems } from '@directus/sdk';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const stuecke = await directus.request(
    readItems('stuecke', {
      filter: {
        status: { _eq: 'published' }
      }
    })
  );

  return stuecke.map((stueck) => ({
    params: { slug: stueck.id },
    props: { stueck },
  }));
}

const { stueck } = Astro.props;
const DIRECTUS_URL = 'https://cms.kopfarbeit.dev';
---

<Layout title={stueck.titel}>
  <div class="container page-header">
    <a href="/stuecke" class="back-link">&larr; Zurück zur Übersicht</a>
    <h1>{stueck.titel}</h1>
    <p class="play-year">Aufgeführt: {stueck.auffuehrung_im_jahr}</p>
  </div>

  <section class="container play-detail">
    <div class="glass-panel content-box">
      <h2>Zusammenfassung</h2>
      <div class="abstract">
        {stueck.synopsis ? (
          <div set:html={stueck.synopsis} />
        ) : (
          <p>Keine Beschreibung verfügbar.</p>
        )}
      </div>
      
      {stueck.foto_gallerie && stueck.foto_gallerie.length > 0 && (
        <div class="gallery">
          <h3>Galerie</h3>
          <div class="grid-3">
            {stueck.foto_gallerie.map((item, index) => item.directus_files_id && (
              <Image 
                src={`${DIRECTUS_URL}/assets/${item.directus_files_id}`} 
                alt={`${stueck.titel} - Galeriebild ${index + 1}`} 
                width={800}
                height={600}
                format="webp"
              />
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  .back-link:hover {
    color: var(--accent-green);
  }

  .play-year {
    color: var(--accent-green);
    font-size: 1.2rem;
    font-weight: bold;
  }

  .play-detail {
    max-width: 800px;
    margin-bottom: 5rem;
  }

  .content-box {
    padding: 3rem;
  }

  .abstract {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .gallery {
    margin-top: 3rem;
  }

  .gallery h3 {
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
  }

  .grid-3 {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .gallery img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: var(--transition);
  }

  .gallery img:hover {
    transform: scale(1.02);
    border-color: var(--accent-green);
    box-shadow: 0 4px 20px rgba(143, 194, 56, 0.2);
  }

  .gallery-placeholder {
    margin-top: 3rem;
    padding: 3rem;
    background-color: var(--bg-color);
    border: 1px dashed rgba(255, 255, 255, 0.2);
    border-radius: var(--radius-md);
    text-align: center;
    color: var(--text-muted);
  }
</style>
