---
import '../styles/global.css';
import Logo from '../components/Logo.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import UmamiAnalytics from '../components/UmamiAnalytics.astro';
import SocialLinks from '../components/SocialLinks.astro';
import { Menu } from '@lucide/astro';
import directus from '../lib/directus';
import { readSingleton } from '@directus/sdk';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description = 'Die Theatergruppe Kleinraming präsentiert professionelles Amateurtheater mit Herz und Leidenschaft.',
  image = '/assets/hero-stage.webp',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;
const pathname = new URL(Astro.request.url).pathname;
// Remove trailing slash for comparison (except for home page)
const normalizedPath =
  pathname.endsWith('/') && pathname.length > 1
    ? pathname.slice(0, -1)
    : pathname;

// Fetch ticket promotion status for the menu
const ticketPromo = await directus
  .request(readSingleton('ticket_promotion', { fields: ['anzeige_modus'] }))
  .catch(() => ({ anzeige_modus: 'inaktiv' }));
const isTicketsActive = ticketPromo?.anzeige_modus !== 'inaktiv';
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Font Preloading -->
    <link
      rel="preload"
      href="/fonts/inter-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-500.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/inter-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/outfit-600.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/outfit-700.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/outfit-800.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Primary Meta Tags -->
    <title>{title} | Theatergruppe Kleinraming</title>
    <meta name="title" content={`${title} | Theatergruppe Kleinraming`} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Theme Initialization Script (Prevent FOUC) -->
    <script is:inline>
      const theme = (() => {
        if (
          typeof localStorage !== 'undefined' &&
          localStorage.getItem('theme')
        ) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          return 'light';
        }
        return 'dark';
      })();

      if (theme === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    </script>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta
      property="og:title"
      content={`${title} | Theatergruppe Kleinraming`}
    />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta
      property="twitter:title"
      content={`${title} | Theatergruppe Kleinraming`}
    />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <UmamiAnalytics />
  </head>
  <body>
    <header class="main-header">
      <div class="container header-content">
        <a href="/" class="logo-link" aria-label="Startseite">
          <Logo />
        </a>

        <div class="header-actions">
          <nav class="main-nav" id="main-nav" aria-label="Hauptmenü">
            <a href="/" class={normalizedPath === '/' ? 'active' : ''}>Start</a>
            {
              isTicketsActive && (
                <a
                  href="/tickets"
                  class={normalizedPath === '/tickets' ? 'active' : ''}
                >
                  Tickets
                </a>
              )
            }
            <a
              href="/theatermenschen"
              class={normalizedPath === '/theatermenschen' ? 'active' : ''}
              >Theatermenschen</a
            >
            <a
              href="/stuecke"
              class={normalizedPath.startsWith('/stuecke') ? 'active' : ''}
              >Stücke</a
            >
            <a
              href="/mitmachen"
              class={normalizedPath === '/mitmachen' ? 'active' : ''}
              >Mitwirken</a
            >
            <a
              href="/sponsoren"
              class={normalizedPath === '/sponsoren' ? 'active' : ''}
              >Sponsoren</a
            >
          </nav>

          <div class="header-controls">
            <ThemeToggle />
            <button
              id="mobile-menu-toggle"
              class="mobile-menu-toggle"
              aria-label="Menü wechseln"
              aria-expanded="false"
              aria-controls="main-nav"
            >
              <Menu size={24} />
            </button>
          </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="main-footer">
      <div class="container footer-content">
        <div class="footer-links">
          <a href="/kontakt">Kontakt & FAQ</a>
          <a href="/impressum">Impressum</a>
          <a href="/datenschutz">Datenschutz</a>
        </div>
        <SocialLinks umamiSource="footer" />
      </div>

      <div class="container footer-bottom">
        <p>
          &copy; {new Date().getFullYear()} Theatergruppe Kleinraming. Alle Rechte
          vorbehalten.
        </p>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById('mobile-menu-toggle');
      const nav = document.getElementById('main-nav');
      if (toggle && nav) {
        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const isOpen = nav.classList.toggle('open');
          toggle.setAttribute('aria-expanded', isOpen.toString());
        });

        document.addEventListener('click', (e) => {
          const target = e.target as Node;
          if (
            nav.classList.contains('open') &&
            !nav.contains(target) &&
            !toggle.contains(target)
          ) {
            nav.classList.remove('open');
            toggle.setAttribute('aria-expanded', 'false');
          }
        });
      }
    </script>
  </body>
</html>

<style is:global>
  /* Critical CSS for Header/Nav to prevent flickering */
  .main-header {
    background-color: rgba(var(--bg-color-rgb), 0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--glass-border);
    height: 80px; /* Fixed height for stability */
  }

  .main-nav {
    display: none; /* Mobile first: hidden by default */
  }

  @media (min-width: 1024px) {
    .main-nav {
      display: flex !important; /* Force visible on desktop immediately */
      position: static;
      flex-direction: row;
      background-color: transparent;
      padding: 0;
      border: none;
      gap: 2rem;
    }

    .mobile-menu-toggle {
      display: none !important;
    }
  }

  .main-nav.open {
    display: flex;
  }
</style>

<style>
  .main-header {
    background-color: rgba(var(--bg-color-rgb), 0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid var(--glass-border);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 440px) {
    .header-actions {
      gap: 2rem;
    }
  }

  .header-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .logo-link {
    text-decoration: none;
    display: inline-block;
  }

  .mobile-menu-toggle {
    display: block;
    background: transparent;
    border: none;
    color: var(--text-main);
    cursor: pointer;
    padding: 0.5rem;
  }

  .main-nav {
    display: none;
    position: absolute;
    top: 80px;
    left: 0;
    right: 0;
    background-color: var(--bg-color);
    padding: 2rem;
    flex-direction: column;
    gap: 1.5rem;
    border-bottom: 1px solid var(--card-border);
  }

  .main-nav.open {
    display: flex;
  }

  .main-nav a {
    color: var(--text-main);
    font-weight: 500;
    font-size: 1.1rem;
    text-align: center;
  }

  .main-nav a:hover {
    color: var(--accent-green);
  }

  .main-nav a.active {
    color: var(--accent-green);
    position: relative;
  }

  @media (min-width: 1024px) {
    .main-nav a.active::after {
      content: '';
      position: absolute;
      bottom: -5px;
      left: 0;
      width: 100%;
      height: 2px;
      background-color: var(--accent-green);
      border-radius: 2px;
    }
  }

  main {
    min-height: calc(100svh - 80px - 100px); /* Adjust for header/footer */
  }

  @media (min-width: 1024px) {
    .mobile-menu-toggle {
      display: none;
    }

    .main-nav {
      display: flex;
      position: static;
      flex-direction: row;
      background-color: transparent;
      padding: 0;
      border: none;
      gap: 1.5rem;
    }

    .main-nav a {
      font-size: 1rem;
    }
  }

  .main-footer {
    background-color: var(--bg-color-light);
    padding: 2rem 0;
    margin-top: 4rem;
    border-top: 1px solid var(--card-border);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 1024px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .footer-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-links a:hover {
    color: var(--accent-green);
  }

  .footer-bottom {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--card-border);
    text-align: center;
    color: var(--text-muted);
    font-size: 0.85rem;
  }
</style>
