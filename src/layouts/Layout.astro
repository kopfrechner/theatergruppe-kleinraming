---
import "../styles/global.css";
import Logo from "../components/Logo.astro";
import directus from "../lib/directus";
import { readSingleton } from "@directus/sdk";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Die Theatergruppe Kleinraming präsentiert." } =
  Astro.props;
const pathname = new URL(Astro.request.url).pathname;
// Remove trailing slash for comparison (except for home page)
const normalizedPath =
  pathname.endsWith("/") && pathname.length > 1
    ? pathname.slice(0, -1)
    : pathname;

// Fetch ticket promotion status for the menu
const ticketPromo = await directus
  .request(readSingleton("ticket_promotion", { fields: ["aktiv"] }))
  .catch(() => ({ aktiv: false }));
const isTicketsActive = ticketPromo?.aktiv;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Theatergruppe Kleinraming</title>
  </head>
  <body>
    <header class="main-header">
      <div class="container header-content">
        <a href="/" class="logo-link" aria-label="Startseite">
          <Logo />
        </a>
        <button
          id="mobile-menu-toggle"
          class="mobile-menu-toggle"
          aria-label="Menü wechseln"
        >
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            stroke="currentColor"
            stroke-width="2"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><line x1="3" y1="12" x2="21" y2="12"></line><line
              x1="3"
              y1="6"
              x2="21"
              y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg
          >
        </button>
        <nav class="main-nav" id="main-nav">
          <a href="/" class={normalizedPath === "/" ? "active" : ""}>Start</a>
          {
            isTicketsActive && (
              <a
                href="/tickets"
                class={normalizedPath === "/tickets" ? "active" : ""}
              >
                Tickets
              </a>
            )
          }
          <a
            href="/theatermenschen"
            class={normalizedPath === "/theatermenschen" ? "active" : ""}
            >Theatermenschen</a
          >
          <a
            href="/stuecke"
            class={normalizedPath.startsWith("/stuecke") ? "active" : ""}
            >Stücke</a
          >
          <a
            href="/sponsoren"
            class={normalizedPath === "/sponsoren" ? "active" : ""}>Sponsoren</a
          >
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="main-footer">
      <div class="container footer-content">
        <div class="footer-links">
          <a href="/mitmachen">Mitmachen</a>
          <a href="/kontakt">Kontakt & FAQ</a>
          <a href="/impressum">Impressum</a>
          <a href="/datenschutz">Datenschutz</a>
        </div>
        <div class="social-links">
          <a
            href="https://www.facebook.com/Theatergruppe.Kleinraming/"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon facebook"
            aria-label="Facebook"
          >
            <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a
            href="https://www.instagram.com/theatergruppe.kleinraming/"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon instagram"
            aria-label="Instagram"
          >
            <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="url(#insta-grad)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
          </a>
        </div>
      </div>
      
      <!-- Shared SVG Gradients -->
      <svg width="0" height="0" style="position: absolute;">
        <defs>
          <linearGradient id="insta-grad" x1="100%" y1="100%" x2="0%" y2="0%">
            <stop stop-color="#f09433" offset="0%"></stop>
            <stop stop-color="#e6683c" offset="25%"></stop>
            <stop stop-color="#dc2743" offset="50%"></stop>
            <stop stop-color="#cc2366" offset="75%"></stop>
            <stop stop-color="#bc1888" offset="100%"></stop>
          </linearGradient>
        </defs>
      </svg>
    </footer>

    <script>
      const toggle = document.getElementById("mobile-menu-toggle");
      const nav = document.getElementById("main-nav");
      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          nav.classList.toggle("open");
        });
      }
    </script>
  </body>
</html>

<style>
  .main-header {
    background-color: rgba(15, 14, 13, 0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255, 230, 200, 0.05);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 80px;
  }

  .logo-link {
    text-decoration: none;
    display: inline-block;
  }

  .mobile-menu-toggle {
    display: block;
    background: transparent;
    border: none;
    color: var(--text-main);
    cursor: pointer;
    padding: 0.5rem;
  }

  .main-nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--bg-color);
    padding: 2rem;
    flex-direction: column;
    gap: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .main-nav.open {
    display: flex;
  }

  .main-nav a {
    color: var(--text-main);
    font-weight: 500;
    font-size: 1.1rem;
    text-align: center;
  }

  .main-nav a:hover {
    color: var(--accent-green);
  }

  .main-nav a.active {
    color: var(--accent-green);
    position: relative;
  }

  @media (min-width: 768px) {
    .main-nav a.active::after {
      content: "";
      position: absolute;
      bottom: -5px;
      left: 0;
      width: 100%;
      height: 2px;
      background-color: var(--accent-green);
      border-radius: 2px;
    }
  }

  main {
    min-height: calc(100vh - 80px - 100px); /* Adjust for header/footer */
  }

  @media (min-width: 768px) {
    .mobile-menu-toggle {
      display: none;
    }

    .main-nav {
      display: flex;
      position: static;
      flex-direction: row;
      background-color: transparent;
      padding: 0;
      border: none;
      gap: 2rem;
    }

    .main-nav a {
      font-size: 1rem;
    }
  }

  .main-footer {
    background-color: var(--bg-color-light);
    padding: 2rem 0;
    margin-top: 4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
    }
  }

  .footer-links,
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .footer-links a,
  .social-links a {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .social-icon.facebook {
    color: #1877f2 !important;
  }

  .social-icon:hover {
    transform: translateY(-2px);
    filter: brightness(1.3);
  }

  .footer-links a:hover {
    color: var(--accent-green);
  }
</style>
